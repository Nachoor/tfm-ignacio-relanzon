@functools.lru_cache(maxsize=8192)
def _canonical_skill_cached(skill_str: str) -> str:
    """Inner cached function — always receives a clean str."""
    s = normalize_match_text(skill_str)
    if s in {"c++", "c#"}:
        return s
    s = re.sub(r"[^a-z0-9]+", "_", s).strip("_")
    return SKILL_CANONICAL_SYNONYMS.get(s, s)


def canonical_skill_name(skill: str) -> str:
    """Public API: accepts any type, caches on normalized str key."""
    return _canonical_skill_cached(str(skill or ""))


def role_terms(target_role: str) -> list[str]:
    txt = re.sub(r"[_\-]+", " ", str(target_role or "").strip()).lower()
    return [t for t in re.split(r"[^a-z0-9]+", txt) if len(t) > 2]


def text_role_overlap_score(text_value: str, target_role: str) -> float | None:
    terms = role_terms(target_role)
    if not terms:
        return None
    txt = str(text_value or "").lower()
    if not txt.strip():
        return None
    hit = sum(1 for t in terms if t in txt)
    return float(max(0.0, min(1.0, hit / len(terms))))


def extract_skills(text: str, taxonomy: dict) -> list[str]:
    txt = norm_text(text).lower()
    if not txt:
        return []
    found = []
    for skill, aliases in taxonomy.items():
        for alias in aliases:
            if contains_term(txt, alias):
                found.append(skill)
                break
    return sorted(set(found))


