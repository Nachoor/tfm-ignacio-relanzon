def normalize_match_text(text: str) -> str:
    txt = str(text or "").lower()
    txt = "".join(c for c in unicodedata.normalize("NFD", txt) if unicodedata.category(c) != "Mn")
    # OCR fix: join frequent split prepositions/articles without collapsing acronyms (e.g., MSc).
    txt = re.sub(r"\bd\s+e\b", "de", txt)
    txt = re.sub(r"\be\s+n\b", "en", txt)
    txt = re.sub(r"\ba\s+l\b", "al", txt)
    txt = re.sub(r"\bl\s+a\b", "la", txt)
    txt = re.sub(r"\bd\s+el\b", "del", txt)
    txt = re.sub(r"\ba\s+n\b", "an", txt)
    txt = re.sub(r"\bi\s+n\b", "in", txt)
    txt = re.sub(r"\bo\s+f\b", "of", txt)
    txt = re.sub(r"\bt\s+o\b", "to", txt)
    txt = re.sub(r"\s+", " ", txt).strip()
    return txt


def contains_term(text: str, term: str) -> bool:
    t = f" {normalize_match_text(text)} "
    q = normalize_match_text(term)
    if q.startswith(" ") or q.endswith(" "):
        return q in t
    if not re.match(r"^[a-z0-9]+$", q):
        return re.search(rf"(?<![a-z0-9]){re.escape(q)}(?![a-z0-9])", t) is not None
    return re.search(rf"\b{re.escape(q)}\b", t) is not None


