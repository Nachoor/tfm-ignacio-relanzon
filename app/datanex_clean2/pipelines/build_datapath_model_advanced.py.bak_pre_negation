def _normalize_for_search(text: str) -> str:
    return normalize_match_text(norm_text(text))


@functools.lru_cache(maxsize=8192)
def infer_master_focus_tags(text: str) -> list[str]:
    low = _normalize_for_search(text)
    if not low:
        return []
    scored = []
    for tag, kws in MASTER_FOCUS_KEYWORDS.items():
        hits = sum(1 for kw in kws if contains_term(low, kw))
        if hits > 0:
            scored.append((tag, hits))
    scored.sort(key=lambda x: x[1], reverse=True)
    return [t for t, _ in scored]


def split_resume_sections(text: str) -> dict:
    raw_lines = [ln.strip() for ln in str(text or "").splitlines()]
    lines = [ln for ln in raw_lines if ln]
    sections = {k: [] for k in SECTION_KEYWORDS.keys()}
    current = "experience"
    for ln in lines:
        low = ln.lower()
        assigned = None
        for sec, keys in SECTION_KEYWORDS.items():
            if any(k in low for k in keys):
                assigned = sec
                break
        if assigned:
            current = assigned
            continue
        sections[current].append(ln)

    full = _normalize_for_search(text)
    out = {}
    for sec in SECTION_KEYWORDS.keys():
        sec_txt = " ".join(sections.get(sec, []))
        if not sec_txt:
            anchors = [k for k in SECTION_KEYWORDS[sec] if k in full]
            if anchors:
                idx = full.find(anchors[0])
                sec_txt = full[max(0, idx - 400) : min(len(full), idx + 1800)]
        out[sec] = norm_text(sec_txt)
    out["full_text"] = norm_text(text)
    return out


def _skill_display_name(skill: str) -> str:
    return str(skill or "").replace("_", " ").strip()


def _build_resume_semantic_chunks(sections: dict) -> list[dict]:
    chunks = []
    seen = set()
    section_order = ["experience", "projects", "education", "skills", "certifications", "full_text"]
    split_pattern = re.compile(r"[\n\r]+|(?<=[\.\!\?;:])\s+|[•\-]{1,2}\s+")
    for section_name in section_order:
        raw = norm_text((sections or {}).get(section_name, ""))
        if not raw:
            continue
        for piece in split_pattern.split(raw):
            chunk = norm_text(piece)
            if len(chunk) < 30 or len(chunk) > 320:
                continue
            key = normalize_match_text(chunk)
            if not key or key in seen:
                continue
            seen.add(key)
            chunks.append({
                "section": section_name,
                "text": chunk,
            })
    return chunks


def infer_semantic_skills_from_resume(
    sections: dict,
    taxonomy: dict,
    existing_skills: set[str] | None = None,
    max_skills: int = SEMANTIC_INFERENCE_MAX_SKILLS,
) -> tuple[list[dict], str]:
    existing = {canonical_skill_name(s) for s in (existing_skills or set()) if canonical_skill_name(s)}
    chunks = _build_resume_semantic_chunks(sections or {})
    if not chunks or not taxonomy:
        return [], "none"

    skill_rows = []
    skill_docs = []
    for skill, aliases in (taxonomy or {}).items():
        can = canonical_skill_name(skill)
        if not can or can in existing:
            continue
        alias_terms = []
        for alias in ([skill] + list(aliases or [])):
            a = norm_text(alias)
            if not a:
                continue
            norm_alias = normalize_match_text(a)
            if norm_alias in alias_terms:
                continue
            alias_terms.append(norm_alias)
            if len(alias_terms) >= 8:
                break
        if not alias_terms or can not in SEMANTIC_FREE_INFERENCE_ALLOWLIST:
            continue
        skill_rows.append({
            "skill": can,
            "display": _skill_display_name(skill),
            "aliases": alias_terms,
        })
        skill_docs.append(" ; ".join(alias_terms))

    if not skill_docs:
        return [], "none"

    chunk_docs = [c["text"] for c in chunks]
    try:
        emb, emb_mode = embed_texts(skill_docs + chunk_docs)
        skill_emb = emb[: len(skill_docs)]
        chunk_emb = emb[len(skill_docs) :]
        sim = cosine_similarity_matrix(skill_emb, chunk_emb)
    except Exception:
        return [], "none"

    threshold = float(SEMANTIC_INFERENCE_THRESHOLDS.get(emb_mode, 0.18))
    out = []
    for idx, row in enumerate(skill_rows):
        score_vec = np.asarray(sim[idx]).ravel()
        if score_vec.size < 1:
            continue
        best_idx = int(np.argmax(score_vec))
        best_sim = float(score_vec[best_idx])
        if best_sim < threshold:
            continue
        support = chunks[best_idx]
        section = str(support.get("section", "resume") or "resume")
        if section not in {"experience", "projects", "skills"}:
            continue
        section_bonus = 0.05 if section in {"experience", "projects"} else 0.0
        weight = min(0.82, 0.55 + section_bonus + max(0.0, best_sim - threshold) * 0.8)
        out.append({
            "skill": row["display"],
            "source": "semantic_nlp",
            "reason": f"Semantic NLP match in {section}: {support.get('text', '')[:160]}",
            "weight": round(float(weight), 2),
            "similarity": round(best_sim, 3),
        })

    out.sort(key=lambda item: (float(item.get("similarity", 0.0)), float(item.get("weight", 0.0))), reverse=True)
    return out[:max_skills], emb_mode


def infer_contextual_nlp_skills(
    sections: dict,
    existing_skills: set[str] | None = None,
) -> list[dict]:
    existing = {canonical_skill_name(s) for s in (existing_skills or set()) if canonical_skill_name(s)}
    full_text = _normalize_for_search((sections or {}).get("full_text", ""))
    if not full_text:
        return []

    inferred = []
    for rule in CONTEXTUAL_NLP_PATTERNS:
        terms = rule.get("terms", []) or []
        if not any(contains_term(full_text, term) for term in terms):
            continue
        for skill in rule.get("skills", []) or []:
            can = canonical_skill_name(skill)
            if not can or can in existing or can not in CONTEXTUAL_NLP_ALLOWLIST:
                continue
            inferred.append({
                "skill": _skill_display_name(can),
                "source": "semantic_nlp",
                "reason": f"{rule.get('reason', 'Contextual NLP match')}: {terms[0]}",
                "weight": 0.64,
                "similarity": 0.2,
            })
            existing.add(can)
    return inferred


def _to_month_index(year: int, month: int) -> int:
    return year * 12 + max(1, min(12, month))


def _year_from_month_index(idx: int) -> int:
    return int((max(1, idx) - 1) // 12)


def _month_from_month_index(idx: int) -> int:
    return int(((max(1, idx) - 1) % 12) + 1)


def _month_from_token(tok: str):
    if tok is None:
        return None
    t = re.sub(r"[^a-záéíóúüñ]", "", str(tok or "").lower())
    if not t:
        return None
    if t in MONTH_ALIASES:
        return MONTH_ALIASES[t]
    # OCR fallback: token may contain month substring (e.g., "ltantsept").
    for k, v in MONTH_ALIASES.items():
        if len(k) >= 3 and k in t:
            return v
    return None


def extract_date_ranges(text: str) -> list[tuple[int, int, float]]:
    txt = str(text or "")
    now = datetime.utcnow()
    current_month_idx = _to_month_index(now.year, now.month)
    ranges = []

    pattern = re.compile(
        r"(?:(?P<m1>[A-Za-zÁÉÍÓÚáéíóúñÑ]{3,12})\s+)?(?P<y1>20\d{2}|19\d{2})\s*[-–to]+\s*(?:(?P<m2>[A-Za-zÁÉÍÓÚáéíóúñÑ]{3,12})\s+)?(?P<y2>20\d{2}|19\d{2}|present|current|actualidad|now)",
        flags=re.IGNORECASE,
    )
    for m in pattern.finditer(txt):
        y1 = int(m.group("y1"))
        y2_raw = str(m.group("y2")).lower()
        if y2_raw in {"present", "current", "actualidad", "now"}:
            y2 = now.year
            m2 = now.month
        else:
            y2 = int(y2_raw)
            m2 = _month_from_token(m.group("m2")) if m.group("m2") else 12
            if m2 is None:
                m2 = 12
        m1 = _month_from_token(m.group("m1")) if m.group("m1") else 1
        if m1 is None:
            m1 = 1
        m1_raw = m.group("m1")
        m2_raw_tok = m.group("m2")
        if (m1_raw is None and m2_raw_tok is None and y2_raw not in {"present", "current", "actualidad", "now"} and y1 == int(y2_raw)):
            # Ambiguous "2025 - 2025" pattern; often from merged OCR lines.
            continue
        start = _to_month_index(y1, m1)
        end = min(_to_month_index(y2, m2), current_month_idx)
        if end >= start:
            ranges.append((start, end, 0.9))

    year_pair = re.compile(r"\b(19\d{2}|20\d{2})\s*[-–]\s*(19\d{2}|20\d{2}|present|current)\b", flags=re.IGNORECASE)
    for m in year_pair.finditer(txt):
        y1 = int(m.group(1))
        y2_raw = str(m.group(2)).lower()
        y2 = now.year if y2_raw in {"present", "current"} else int(y2_raw)
        start = _to_month_index(y1, 1)
        end = min(_to_month_index(y2, now.month if y2_raw in {"present", "current"} else 12), current_month_idx)
        if end >= start:
            ranges.append((start, end, 0.7))

    dedup = []
    for r in sorted(ranges, key=lambda x: (x[0], x[1])):
        if dedup and abs(r[0] - dedup[-1][0]) <= 1 and abs(r[1] - dedup[-1][1]) <= 1:
            continue
        dedup.append(r)
    return dedup


WORK_CONTEXT_TERMS = [
    "consultant", "analyst", "engineer", "scientist", "specialist", "associate",
    "coordinator", "manager", "lead", "delegate", "developer", "architect",
    "responsible", "client", "company", "empleo", "puesto", "cargo", "trabajo",
    "engineered", "developed", "implemented", "pipeline", "project", "projects",
    "consultor", "analista", "ingeniero",
]

EDU_CONTEXT_TERMS = [
    "university", "universidad", "graduated", "grade", "degree", "master", "bachelor",
    "erasmus", "high school", "academic", "student", "estudios", "formacion", "formación",
    "colegio", "school",
]

INTERNSHIP_TERMS = ["intern", "internship", "trainee", "becario", "practicas", "prácticas", "graduate program"]
NON_PROF_CONTEXT_TERMS = ["volunteer", "voluntariado", "ngo", "tutor", "tutoring", "coach", "field mission"]


def extract_experience_section_date_ranges(text: str) -> list[tuple[int, int, float]]:
    txt = str(text or "")
    low = txt.lower()
    now = datetime.utcnow()
    current_month_idx = _to_month_index(now.year, now.month)
    out = []
    pattern = re.compile(
        r"(?:(?P<m1>[A-Za-zÁÉÍÓÚáéíóúñÑ]{3,12})\s+)?(?P<y1>20\d{2}|19\d{2})\s*[-–to]+\s*(?:(?P<m2>[A-Za-zÁÉÍÓÚáéíóúñÑ]{3,12})\s+)?(?P<y2>20\d{2}|19\d{2}|present|current|actualidad|now)",
        flags=re.IGNORECASE,
    )
    for m in pattern.finditer(txt):
        ctx_start = max(0, m.start() - 120)
        ctx_end = min(len(low), m.end() + 120)
        ctx = low[ctx_start:ctx_end]
        work_hits = sum(1 for t in WORK_CONTEXT_TERMS if t in ctx)
        edu_hits = sum(1 for t in EDU_CONTEXT_TERMS if t in ctx)
        if work_hits < 1:
            continue
        if edu_hits >= 2 and work_hits < 2:
            continue

        y1 = int(m.group("y1"))
        y2_raw = str(m.group("y2")).lower()
        if y2_raw in {"present", "current", "actualidad", "now"}:
            y2 = now.year
            m2 = now.month
        else:
            y2 = int(y2_raw)
            m2 = _month_from_token(m.group("m2")) if m.group("m2") else 12
            if m2 is None:
                m2 = 12
        m1 = _month_from_token(m.group("m1")) if m.group("m1") else 1
        if m.group("m1") and m1 is None:
            continue
        if m1 is None:
            m1 = 1
        start = _to_month_index(y1, m1)
        end = min(_to_month_index(y2, m2), current_month_idx)
        if end >= start:
            conf = 0.8 if work_hits >= 2 else 0.68
            out.append((start, end, conf))

    dedup = []
    for r in sorted(out, key=lambda x: (x[0], x[1], -x[2])):
        if dedup and abs(r[0] - dedup[-1][0]) <= 1 and abs(r[1] - dedup[-1][1]) <= 1:
            continue
        dedup.append(r)
    return dedup


def extract_professional_date_ranges(text: str) -> list[tuple[int, int, float]]:
    txt = str(text or "")
    low = txt.lower()
    now = datetime.utcnow()
    current_month_idx = _to_month_index(now.year, now.month)
    out = []

    pattern = re.compile(
        r"(?:(?P<m1>[A-Za-zÁÉÍÓÚáéíóúñÑ]{3,12})\s+)?(?P<y1>20\d{2}|19\d{2})\s*[-–to]+\s*(?:(?P<m2>[A-Za-zÁÉÍÓÚáéíóúñÑ]{3,12})\s+)?(?P<y2>20\d{2}|19\d{2}|present|current|actualidad|now)",
        flags=re.IGNORECASE,
    )
    for m in pattern.finditer(txt):
        ctx_start = max(0, m.start() - 140)
        ctx_end = min(len(low), m.end() + 140)
        ctx = low[ctx_start:ctx_end]
        work_hits = sum(1 for t in WORK_CONTEXT_TERMS if t in ctx)
        edu_hits = sum(1 for t in EDU_CONTEXT_TERMS if t in ctx)
        intern_hits = sum(1 for t in INTERNSHIP_TERMS if t in ctx)
        non_prof_hits = sum(1 for t in NON_PROF_CONTEXT_TERMS if t in ctx)
        is_open_ended = str(m.group("y2")).lower() in {"present", "current", "actualidad", "now"}
        if intern_hits > 0:
            continue
        if non_prof_hits > 0 and work_hits < 2:
            continue
        if work_hits < 1 and not (is_open_ended and edu_hits == 0):
            continue
        if edu_hits >= 2 and work_hits <= 1:
            continue
        if edu_hits >= (work_hits + 2):
            continue

        y1 = int(m.group("y1"))
        y2_raw = str(m.group("y2")).lower()
        if y2_raw in {"present", "current", "actualidad", "now"}:
            y2 = now.year
            m2 = now.month
        else:
            y2 = int(y2_raw)
            m2 = _month_from_token(m.group("m2")) if m.group("m2") else 12
            if m2 is None:
                m2 = 12
        m1 = _month_from_token(m.group("m1")) if m.group("m1") else 1
        if m.group("m1") and m1 is None:
            # Corrupted month token (OCR): skip unreliable range.
            continue
        if m1 is None:
            m1 = 1
        start = _to_month_index(y1, m1)
        end = min(_to_month_index(y2, m2), current_month_idx)
        if end >= start:
            conf = 0.9 if work_hits >= 2 else (0.78 if is_open_ended else 0.75)
            out.append((start, end, conf))

    return out


def extract_internship_date_ranges(text: str) -> list[tuple[int, int, float]]:
