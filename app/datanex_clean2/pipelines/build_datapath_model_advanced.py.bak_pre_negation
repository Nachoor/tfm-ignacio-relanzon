def merge_month_ranges(ranges: list[tuple[int, int, float]]) -> list[tuple[int, int]]:
    if not ranges:
        return []
    base = sorted([(s, e) for s, e, _ in ranges], key=lambda x: x[0])
    out = [base[0]]
    for s, e in base[1:]:
        ls, le = out[-1]
        if s <= le + 1:
            out[-1] = (ls, max(le, e))
        else:
            out.append((s, e))
    return out


def total_months_from_ranges(ranges: list[tuple[int, int]]) -> int:
    return int(sum(max(0, e - s + 1) for s, e in ranges))


def subtract_month_ranges(
    base_ranges: list[tuple[int, int]],
    subtract_ranges: list[tuple[int, int]],
) -> list[tuple[int, int]]:
    if not base_ranges:
        return []
    if not subtract_ranges:
        return list(base_ranges)
    out = []
    for bs, be in base_ranges:
        segments = [(bs, be)]
        for ss, se in subtract_ranges:
            next_segments = []
            for cs, ce in segments:
                if se < cs or ss > ce:
                    next_segments.append((cs, ce))
                    continue
                if ss > cs:
                    next_segments.append((cs, ss - 1))
                if se < ce:
                    next_segments.append((se + 1, ce))
            segments = next_segments
            if not segments:
                break
        out.extend(segments)
    return merge_month_ranges([(s, e, 1.0) for s, e in out])


def infer_graduation_year(education_text: str) -> int | None:
    txt = str(education_text or "")
    m = re.search(r"graduated\s*[:\-]?\s*(19\d{2}|20\d{2})", txt, flags=re.IGNORECASE)
    if m:
        return int(m.group(1))
    m2 = re.search(r"(graduado|graduation|completed)\s*[:\-]?\s*(19\d{2}|20\d{2})", txt, flags=re.IGNORECASE)
    if m2:
        return int(m2.group(2))
    years = [int(y) for y in re.findall(r"\b(19\d{2}|20\d{2})\b", txt)]
    if not years:
        return None
    current_year = datetime.utcnow().year + 1
    years = [y for y in years if 1950 <= y <= current_year]
    return max(years) if years else None


def infer_seniority(total_years: float, text: str) -> tuple[str, float]:
    """Infiere nivel de seniority combinando señales léxicas explícitas y años de experiencia.

    Prioridad de señales (de mayor a menor):
      1. Marcadores de intern/trainee con experiencia baja → student_intern
      2. Marcadores de manager/lead CON respaldo numérico suficiente → lead_manager / senior
      3. Marcadores explícitos de senior/junior → senior / junior (con umbral mínimo)
      4. Reglas numéricas puras cuando no hay señal léxica
    """
    low = _normalize_for_search(text)
    has_intern_markers = any(k in low for k in ["intern", "trainee", "student", "becario", "graduate program"])
    has_manager_markers = any(k in low for k in ["lead", "principal", "head of", "manager", "director"])
    has_senior_markers = any(k in low for k in ["senior", "sr."])
    has_junior_markers = any(k in low for k in ["junior", "jr."])

    # 1. Intern/trainee siempre prevalece si experiencia es baja
    if has_intern_markers and total_years < 1.5:
        return "student_intern", 0.85

    # 2. Manager/lead markers: requiere experiencia mínima para ser creíble
    #    >= 6 años → lead_manager (alta confianza)
    #    3–6 años → senior (señal léxica de liderazgo pero aún no lead; confianza moderada)
    if has_manager_markers and not has_intern_markers:
        if total_years >= 6:
            return "lead_manager", 0.80
        if total_years >= 3.0:
            # Liderazgo con experiencia media: probablemente senior técnico o team lead junior
            return "senior", 0.70

    # 3. Marcador explícito "senior" con respaldo numérico mínimo
    #    Umbral bajado de 4 a 3.5 años para cubrir seniors con progresión rápida
    if has_senior_markers and total_years >= 3.5:
        return "senior", 0.80

    # 4. Marcador explícito "junior" (señal fuerte independientemente de años)
    if has_junior_markers:
        return "junior", 0.75

    # 5. Reglas numéricas puras (sin señal léxica clara)
    if total_years < 1.0:
        return "student_intern", 0.65
    if total_years < 2.5:
        return "junior", 0.70
    if total_years < 5.5:
        return "mid_level", 0.70
    if total_years < 8.5:
        return "senior", 0.70
    return "lead_manager", 0.70


def infer_career_stage(total_years: float, years_since_graduation: float | None, inferred_seniority: str) -> str:
    if inferred_seniority in {"senior", "lead_manager"}:
        return "advanced_stage"
    if inferred_seniority == "mid_level":
        return "growth_stage"
    if inferred_seniority in {"student_intern", "junior"}:
        if years_since_graduation is None:
            return "early_career" if total_years < 1.5 else "growth_stage"
        if years_since_graduation <= 2.0 or total_years < 1.2:
            return "early_career"
        return "growth_stage"
    if total_years >= 5.0:
        return "advanced_stage"
    if total_years < 1.2:
        return "early_career"
    return "growth_stage"


def infer_education_profile(education_text: str, full_text: str, grad_year: int | None = None) -> dict:
    edu = _normalize_for_search(education_text)
    full = _normalize_for_search(full_text)
    # Prioritize explicit education section. Use full-text only as weak fallback.
    txt = edu if len(edu) >= 60 else f"{edu} {full[:3000]}".strip()
    full_limited = full[:22000]

    def _master_context_hits(source_text: str, window: int = 150) -> tuple[int, int]:
        data_hits_local = 0
        non_tech_hits_local = 0
        for m in re.finditer(r"\b(master|masters|m\.sc|msc|maestr[ií]a|postgrado|posgrado)\b", source_text, flags=re.IGNORECASE):
            s = max(0, m.start() - window)
            e = min(len(source_text), m.end() + window)
            ctx = source_text[s:e]
            data_hits_local += sum(1 for t in DATA_EDU_TERMS if contains_term(ctx, t))
            non_tech_hits_local += sum(1 for t in NON_TECH_MASTER_TERMS if contains_term(ctx, t))
        return data_hits_local, non_tech_hits_local

    def _has_data_master_in_source(source_text: str, window: int = 95) -> bool:
        strong_master_data_terms = [
            "big data", "data science", "machine learning", "artificial intelligence",
            "business analytics", "data analytics",
        ]
        for m in re.finditer(r"\b(master|masters|m\.sc|msc|maestr[ií]a|postgrado|posgrado)\b", source_text, flags=re.IGNORECASE):
            s = max(0, m.start() - window)
            e = min(len(source_text), m.end() + window)
            ctx = source_text[s:e]
            if any(contains_term(ctx, t) for t in strong_master_data_terms):
                return True
            d_hits = sum(1 for t in DATA_EDU_TERMS if contains_term(ctx, t))
            n_hits = sum(1 for t in NON_TECH_MASTER_TERMS if contains_term(ctx, t))
            if d_hits >= 2:
                return True
            if d_hits >= 1 and n_hits == 0:
                return True
        return False

    has_phd = any(re.search(p, txt, flags=re.IGNORECASE) for p in EDU_LEVEL_PATTERNS["phd"]) or any(
        re.search(p, full_limited, flags=re.IGNORECASE) for p in EDU_LEVEL_PATTERNS["phd"]
    )
    has_master_local = any(re.search(p, txt, flags=re.IGNORECASE) for p in EDU_LEVEL_PATTERNS["master"])
    has_master_full = any(re.search(p, full_limited, flags=re.IGNORECASE) for p in EDU_LEVEL_PATTERNS["master"])
    has_master = has_phd or has_master_local or has_master_full
    has_bachelor = any(re.search(p, txt, flags=re.IGNORECASE) for p in EDU_LEVEL_PATTERNS["bachelor"])

    data_hits_edu = sum(1 for t in DATA_EDU_TERMS if contains_term(edu, t))
    stem_hits_edu = sum(1 for t in STEM_EDU_TERMS if contains_term(edu, t))
    data_hits_txt = sum(1 for t in DATA_EDU_TERMS if contains_term(txt, t))
    stem_hits_txt = sum(1 for t in STEM_EDU_TERMS if contains_term(txt, t))
    non_tech_hits = sum(1 for t in NON_TECH_MASTER_TERMS if contains_term(edu, t))

    master_ctx_data_hits_edu, master_ctx_non_tech_hits_edu = _master_context_hits(edu, window=160)
    master_ctx_data_hits_full, master_ctx_non_tech_hits_full = _master_context_hits(full_limited, window=140)
    master_ctx_data_hits = master_ctx_data_hits_edu + master_ctx_data_hits_full
    master_ctx_non_tech_hits = master_ctx_non_tech_hits_edu + master_ctx_non_tech_hits_full

    has_data_master_edu = _has_data_master_in_source(edu, window=100)
    has_data_master_full = _has_data_master_in_source(full_limited, window=80)
    has_data_related_master = bool(
        has_master and (
            has_data_master_edu
            or has_data_master_full
            or (master_ctx_non_tech_hits == 0 and data_hits_edu >= 1 and stem_hits_edu >= 1)
        )
    )
    # Master focus tags to avoid redundant "same-domain" recommendations.
    master_focus_tags = []
    if has_master:
        focus_from_edu = infer_master_focus_tags(education_text)
        focus_from_full = infer_master_focus_tags(full_text[:5000])
        ordered = []
        for tag in (focus_from_edu + focus_from_full):
            if tag not in ordered:
                ordered.append(tag)
        # If education explicitly states a Data Science master, keep it as primary focus.
        edu_low = _normalize_for_search(education_text)
        full_low = _normalize_for_search(full_text[:9000])
        explicit_data_science_master = False
        if has_data_related_master:
            explicit_data_science_master = (
                contains_term(edu_low, "big data science")
                or contains_term(edu_low, "data science")
                or contains_term(full_low, "big data science")
                or contains_term(full_low, "data science")
            )
        if explicit_data_science_master:
            ordered = ["data_science"] + [t for t in ordered if t != "data_science"]
        master_focus_tags = ordered[:4]
    master_focus_primary = master_focus_tags[0] if master_focus_tags else "unknown"

    # Confidence grows when explicit level + domain terms are present.
    relevance_base = 0.0
    if has_phd and (data_hits_edu >= 1 or stem_hits_edu >= 2):
        relevance_base += 0.95
    elif has_data_related_master:
        relevance_base += 0.82
    elif has_master:
        # Generic master (e.g., leadership) should not heavily boost data suitability.
        relevance_base += 0.26
    elif has_bachelor:
        relevance_base += 0.45
    relevance_base += min(0.25, 0.05 * data_hits_edu) + min(0.12, 0.03 * stem_hits_edu)
    if (data_hits_edu == 0 or master_ctx_data_hits == 0) and has_master and (non_tech_hits >= 1 or master_ctx_non_tech_hits >= 1):
        relevance_base -= 0.12
    if data_hits_edu == 0 and stem_hits_edu == 0 and has_master:
        relevance_base -= 0.07
    # Weak fallback from full text to avoid missing cases with noisy CV layout.
    relevance_base += min(0.06, 0.01 * max(0, data_hits_txt - data_hits_edu))
    relevance_base += min(0.03, 0.008 * max(0, stem_hits_txt - stem_hits_edu))
    if grad_year is not None:
        relevance_base += 0.03
    data_edu_relevance = float(max(0.0, min(1.0, relevance_base)))

    # Role-specific relevance (more strict for DS/ML/DE).
    role_relevance = {
        "data_analyst": float(max(0.0, min(1.0, 0.75 * data_edu_relevance + 0.10))),
        "other_data_role": float(max(0.0, min(1.0, 0.70 * data_edu_relevance + 0.12))),
        "data_scientist": float(max(0.0, min(1.0, data_edu_relevance))),
        "ml_engineer": float(max(0.0, min(1.0, 0.95 * data_edu_relevance))),
        "data_engineer": float(max(0.0, min(1.0, 0.90 * data_edu_relevance))),
    }

    highest = "none"
    if has_phd:
        highest = "phd"
    elif has_master:
        highest = "master"
    elif has_bachelor:
        highest = "bachelor"

    return {
        "highest_education_level": highest,
        "has_master_degree": bool(has_master),
        "has_phd_degree": bool(has_phd),
        "has_bachelor_degree": bool(has_bachelor),
        "has_data_related_master": has_data_related_master,
        "has_stem_background": bool(stem_hits_edu >= 1 or stem_hits_txt >= 1),
        "master_focus_tags": master_focus_tags,
        "master_focus_primary": master_focus_primary,
        "education_data_relevance": round(data_edu_relevance, 3),
        "education_relevance_by_role": {k: round(v, 3) for k, v in role_relevance.items()},
        "education_signal_confidence": round(float(max(0.3, min(0.95, 0.45 + 0.08 * data_hits_edu + 0.04 * stem_hits_edu))), 2),
    }


def detect_internship_signal(text: str) -> float:
    low = _normalize_for_search(text)
    markers = INTERNSHIP_TERMS
    hits = sum(1 for m in markers if m in low)
    if hits <= 0:
        return 0.0
    return min(1.0, 0.35 + 0.18 * hits)


def build_skill_evidence_map(text: str, taxonomy: dict, sections: dict) -> tuple[dict, dict]:
    full = _normalize_for_search(text)
    exp_txt = _normalize_for_search(sections.get("experience", ""))
    prj_txt = _normalize_for_search(sections.get("projects", ""))
    edu_txt = _normalize_for_search(sections.get("education", ""))
    skl_txt = _normalize_for_search(sections.get("skills", ""))
    crt_txt = _normalize_for_search(sections.get("certifications", ""))

    evidence = {}
    confidence = {}
    for skill, aliases in taxonomy.items():
        if not any(contains_term(full, a) for a in aliases):
            continue
        in_exp = any(contains_term(exp_txt, a) for a in aliases)
        in_prj = any(contains_term(prj_txt, a) for a in aliases)
        in_edu = any(contains_term(edu_txt, a) for a in aliases)
        in_skl = any(contains_term(skl_txt, a) for a in aliases)
        in_crt = any(contains_term(crt_txt, a) for a in aliases)
        if in_exp:
            evidence[skill] = "professional"
            confidence[skill] = 0.9
        elif in_prj:
            evidence[skill] = "project"
            confidence[skill] = 0.75
        elif in_edu or in_crt:
            evidence[skill] = "academic"
            confidence[skill] = 0.65
        elif in_skl:
            evidence[skill] = "declared"
            confidence[skill] = 0.55
        else:
            evidence[skill] = "declared"
            confidence[skill] = 0.5
    return evidence, confidence


def estimate_domain_experience(sections: dict, total_years: float, skills_evidence: dict) -> dict:
    exp_text = _normalize_for_search(sections.get("experience", ""))
    prj_text = _normalize_for_search(sections.get("projects", ""))
    domain_scores = {}
    for domain, kws in DOMAIN_KEYWORDS.items():
        exp_hits = sum(1 for k in kws if contains_term(exp_text, k))
        prj_hits = sum(1 for k in kws if contains_term(prj_text, k))
        skill_hits = 0
        for sk, ev in skills_evidence.items():
            sk_t = sk.replace("_", " ").lower()
            if any(k in sk_t for k in kws):
                skill_hits += 2 if ev == "professional" else 1
        domain_scores[domain] = (2.0 * exp_hits) + (1.2 * prj_hits) + (0.8 * skill_hits)

    max_raw = max(domain_scores.values()) if domain_scores else 0.0
    years = {}
    for domain, raw in domain_scores.items():
        if raw <= 0 or max_raw <= 0:
            years[domain] = 0.0
            continue
        rel = raw / max_raw
        years[domain] = round(total_years * rel * (0.7 + 0.3 * min(1.0, raw / 6.0)), 2)
    return years


def _infer_skills_from_rules(text: str, rules: list[dict], source: str) -> list[dict]:
    low = _normalize_for_search(text)
    if not low:
        return []
    out = []
    for rule in rules:
        terms = [str(t or "").strip().lower() for t in (rule.get("terms", []) or []) if str(t or "").strip()]
        if not terms:
            continue
        if not any(contains_term(low, t) for t in terms):
            continue
        reason = str(rule.get("reason", f"{source} inference")).strip()
        for sk in (rule.get("skills", []) or []):
            s = str(sk or "").strip()
            if not s:
                continue
            out.append({"skill": s, "source": source, "reason": reason})
    return out


def infer_implicit_skills(sections: dict) -> tuple[list[dict], list[dict]]:
    education_text = " ".join(
        [str(sections.get("education", "") or ""), str(sections.get("full_text", "") or "")[:4000]]
    )
    experience_text = " ".join(
        [str(sections.get("experience", "") or ""), str(sections.get("projects", "") or "")]
    )
    edu_inf = _infer_skills_from_rules(education_text, EDUCATION_SKILL_INFERENCE_RULES, "education")
    exp_inf = _infer_skills_from_rules(experience_text, EXPERIENCE_SKILL_INFERENCE_RULES, "experience")
    return edu_inf, exp_inf


def build_candidate_profile_from_resume(resume_text: str, taxonomy: dict) -> dict:
    raw_text = str(resume_text or "")
    txt = norm_text(raw_text)
    sections = split_resume_sections(raw_text)
    exp_text = sections.get("experience", "")
    full_text = sections.get("full_text", "")
    exp_prof_ranges = extract_professional_date_ranges(exp_text)
    full_prof_ranges = extract_professional_date_ranges(full_text)
    professional_ranges = list(exp_prof_ranges)
    for r in full_prof_ranges:
        if not any(abs(r[0] - x[0]) <= 1 and abs(r[1] - x[1]) <= 1 for x in professional_ranges):
            professional_ranges.append(r)

    internship_ranges = extract_internship_date_ranges(exp_text)
    if len(internship_ranges) < 1:
        internship_ranges = extract_internship_date_ranges(full_text)

    # Conservative fallback: if professional ranges are empty, infer from context-aware ranges only.
    if len(professional_ranges) < 1:
        generic_exp_ranges = extract_experience_section_date_ranges(exp_text)
        if len(generic_exp_ranges) < 1:
            generic_exp_ranges = extract_professional_date_ranges(full_text)
        professional_ranges = generic_exp_ranges

    grad_year = infer_graduation_year(sections.get("education", ""))
    if grad_year is None:
        grad_year = infer_graduation_year(full_text)
    education_profile = infer_education_profile(sections.get("education", ""), full_text, grad_year=grad_year)

    if grad_year is not None and professional_ranges:
        now_year = datetime.utcnow().year
        has_current_post_grad_role = any(
            (_year_from_month_index(e) >= now_year) and float(c) >= 0.78
            for _, e, c in professional_ranges
        )
        kept_prof = []
        moved_ranges = []
        current_idx = _to_month_index(datetime.utcnow().year, datetime.utcnow().month)
        for s, e, c in professional_ranges:
            start_year = _year_from_month_index(s)
            start_month = _month_from_month_index(s)
            end_year = _year_from_month_index(e)
            should_move = False
            if has_current_post_grad_role:
                # If there is already current post-grad experience, treat clear pre-grad ranges as pre-professional.
                if end_year < grad_year:
                    should_move = True
                elif end_year == grad_year:
                    is_current_range = e >= (current_idx - 1)
                    if is_current_range:
                        should_move = False
                    else:
                        if start_year < grad_year:
                            should_move = True
                        late_grad_year_prof = (start_year == grad_year and start_month >= 7 and float(c) >= 0.85)
                        if (not should_move) and (not late_grad_year_prof) and float(c) <= 0.85:
                            should_move = True
            elif internship_ranges and end_year <= grad_year and float(c) <= 0.75:
                should_move = True

            if should_move:
                moved_ranges.append((s, e, 0.75))
            else:
                kept_prof.append((s, e, c))
        professional_ranges = kept_prof
        if moved_ranges:
            internship_ranges = internship_ranges + moved_ranges

    merged_prof_raw = merge_month_ranges(professional_ranges)
    merged_intern = merge_month_ranges(internship_ranges) if internship_ranges else []
    # Avoid counting the same timeline as both professional and internship.
    merged_prof = subtract_month_ranges(merged_prof_raw, merged_intern)
    prof_months = total_months_from_ranges(merged_prof)
    internship_months_est = total_months_from_ranges(merged_intern) if merged_intern else 0
    internship_months_est = int(min(internship_months_est, 24))
    experience_years_total = round(prof_months / 12.0, 2)

    now_year = datetime.utcnow().year
    years_since_graduation = None if grad_year is None else max(0.0, round(now_year - grad_year, 1))
    inferred_seniority, seniority_conf = infer_seniority(experience_years_total, txt)
    career_stage = infer_career_stage(experience_years_total, years_since_graduation, inferred_seniority)
    # If explicit internship ranges were not found, keep soft signal estimation.
    if internship_months_est <= 0:
        internship_signal = detect_internship_signal(exp_text + " " + full_text)
        internship_months_est = int(round(min(12, max(prof_months, 6)) * internship_signal)) if internship_signal > 0 else 0
    non_intern_months = max(0, prof_months)
    non_intern_years = round(non_intern_months / 12.0, 2)
    if experience_years_total < 0.25 and grad_year is not None:
        inferred_seniority = "student_intern"
        career_stage = "early_career"
        seniority_conf = max(float(seniority_conf), 0.8)
    elif experience_years_total >= 0.5 and inferred_seniority == "student_intern":
        # If there is already 6+ months of non-intern experience, avoid over-penalizing as intern.
        inferred_seniority = "junior"
        seniority_conf = max(float(seniority_conf), 0.65)
    elif experience_years_total < 0.25 and internship_months_est > 0:
        inferred_seniority = "student_intern"
        career_stage = "early_career"
        seniority_conf = max(float(seniority_conf), 0.75)
    if experience_years_total < 0.25 and grad_year is not None:
        profile_experience_type = "graduate_no_experience"
    elif experience_years_total < 0.25 and internship_months_est <= 0:
        profile_experience_type = "no_experience_detected"
    elif experience_years_total < 0.5 and internship_months_est > 0:
        profile_experience_type = "internship_profile"
    elif experience_years_total < 2.5:
        profile_experience_type = "early_professional"
    else:
        profile_experience_type = "professional_experience"

    skills_evidence, skills_conf = build_skill_evidence_map(txt, taxonomy, sections)
    explicit_skills = sorted(skills_evidence.keys())
    inferred_edu, inferred_exp = infer_implicit_skills(sections)
    semantic_existing = set(explicit_skills)
    semantic_existing.update(str(x.get("skill", "")).strip() for x in inferred_edu if str(x.get("skill", "")).strip())
    semantic_existing.update(str(x.get("skill", "")).strip() for x in inferred_exp if str(x.get("skill", "")).strip())
    inferred_semantic, semantic_mode = infer_semantic_skills_from_resume(
        sections,
        taxonomy,
        existing_skills=semantic_existing,
    )
    semantic_existing.update(str(x.get("skill", "")).strip() for x in inferred_semantic if str(x.get("skill", "")).strip())
    inferred_semantic += infer_contextual_nlp_skills(
        sections,
        existing_skills=semantic_existing,
    )

    merged = {}
    for sk in explicit_skills:
        can = canonical_skill_name(sk)
        if not can:
            continue
        merged[can] = {
            "skill_display": sk,
            "sources": {"explicit"},
            "reasons": {"Explicitly listed in CV"},
            "weight": 1.0,
        }
    for item in inferred_edu + inferred_exp + inferred_semantic:
        sk = str(item.get("skill", "")).strip()
        if not sk:
            continue
        can = canonical_skill_name(sk)
        if not can:
            continue
        src = str(item.get("source", "education")).strip().lower()
        reason = str(item.get("reason", f"Inferred from {src}")).strip()
        if src == "education":
            w = 0.7
        elif src == "semantic_nlp":
            w = float(item.get("weight", 0.62) or 0.62)
        else:
            w = 0.8
        if can not in merged:
            merged[can] = {
                "skill_display": sk,
                "sources": {src},
                "reasons": {reason},
                "weight": w,
            }
        else:
            merged[can]["sources"].add(src)
            merged[can]["reasons"].add(reason)
            if "explicit" not in merged[can]["sources"]:
                merged[can]["weight"] = max(float(merged[can]["weight"]), float(w))
            if {"education", "experience"}.issubset(merged[can]["sources"]) and "explicit" not in merged[can]["sources"]:
                merged[can]["weight"] = max(float(merged[can]["weight"]), 0.85)

    for can, item in merged.items():
        if "explicit" in item["sources"]:
            continue
        srcs = item["sources"]
        if "education" in srcs and "experience" in srcs:
            skills_evidence[item["skill_display"]] = "inferred_education_experience"
            skills_conf[item["skill_display"]] = 0.8
        elif "education" in srcs:
            skills_evidence[item["skill_display"]] = "inferred_education"
            skills_conf[item["skill_display"]] = 0.7
        elif "experience" in srcs:
            skills_evidence[item["skill_display"]] = "inferred_experience"
            skills_conf[item["skill_display"]] = 0.8
        elif "semantic_nlp" in srcs:
            skills_evidence[item["skill_display"]] = "inferred_semantic_nlp"
            skills_conf[item["skill_display"]] = max(
                0.6,
                min(0.85, float(item.get("weight", 0.65))),
            )

    skills_detected = sorted(item["skill_display"] for item in merged.values())
    inferred_skills = [
        {
            "skill": item["skill_display"],
            "source": " + ".join(sorted(s for s in item["sources"] if s != "explicit")) if "explicit" not in item["sources"] else "explicit",
            "reason": "; ".join(sorted(item["reasons"])),
            "weight": round(float(item["weight"]), 2),
        }
        for item in merged.values()
        if "explicit" not in item["sources"]
    ]
    candidate_skill_weight_map = {can: round(float(item["weight"]), 3) for can, item in merged.items()}
    candidate_skill_sources = {
        can: sorted(list(item["sources"]))
        for can, item in merged.items()
    }
    domain_years = estimate_domain_experience(sections, max(experience_years_total, 0.1), skills_evidence)
    experience_years_relevant = round(
        sum(domain_years.get(d, 0.0) for d in ["data_analytics", "machine_learning", "nlp", "llm_genai", "data_engineering", "bi_reporting", "cloud_mlops_devops"]) / 7.0,
        2,
    )

    return {
        "experience_years_total": experience_years_total,
        "experience_months_total": int(prof_months),
        "experience_months_including_internship": int(total_months_from_ranges(merge_month_ranges([(s, e, 1.0) for s, e in (merged_prof + merged_intern)]))),
        "experience_years_non_intern": non_intern_years,
        "internship_months_estimated": int(internship_months_est),
        "has_professional_experience": bool(non_intern_years >= 0.5),
        "profile_experience_type": profile_experience_type,
        "experience_years_relevant": experience_years_relevant,
        "experience_years_relevant_by_domain": domain_years,
        "inferred_seniority": inferred_seniority,
        "seniority_confidence": float(round(seniority_conf, 2)),
        "career_stage": career_stage,
        "graduation_year": grad_year,
        "years_since_graduation": years_since_graduation,
        "highest_education_level": education_profile.get("highest_education_level", "none"),
        "has_master_degree": bool(education_profile.get("has_master_degree", False)),
        "has_phd_degree": bool(education_profile.get("has_phd_degree", False)),
        "has_bachelor_degree": bool(education_profile.get("has_bachelor_degree", False)),
        "has_data_related_master": bool(education_profile.get("has_data_related_master", False)),
        "has_stem_background": bool(education_profile.get("has_stem_background", False)),
        "master_focus_tags": education_profile.get("master_focus_tags", []),
        "master_focus_primary": education_profile.get("master_focus_primary", "unknown"),
        "education_data_relevance": float(education_profile.get("education_data_relevance", 0.0)),
        "education_relevance_by_role": education_profile.get("education_relevance_by_role", {}),
        "education_signal_confidence": float(education_profile.get("education_signal_confidence", 0.4)),
        "first_experience_year": (_year_from_month_index(merged_prof[0][0])) if merged_prof else None,
        "skills_detected_explicit": explicit_skills,
        "skills_inferred_education": sorted({str(x.get("skill", "")).strip() for x in inferred_edu if str(x.get("skill", "")).strip()}),
        "skills_inferred_experience": sorted({str(x.get("skill", "")).strip() for x in inferred_exp if str(x.get("skill", "")).strip()}),
        "skills_inferred_semantic": sorted({str(x.get("skill", "")).strip() for x in inferred_semantic if str(x.get("skill", "")).strip()}),
        "inferred_skills": inferred_skills,
        "candidate_skill_weight_map": candidate_skill_weight_map,
        "candidate_skill_sources": candidate_skill_sources,
        "skills_detected": skills_detected,
        "skills_evidence": skills_evidence,
        "skills_evidence_confidence": skills_conf,
        "semantic_inference_mode": semantic_mode,
        "inference_confidence": float(round(min(0.95, 0.45 + 0.1 * bool(grad_year) + 0.2 * bool(merged_prof) + 0.25 * min(1.0, len(skills_detected) / 15.0)), 2)),
    }


def _env_flag(name: str, default: bool = False) -> bool:
    val = str(os.getenv(name, "1" if default else "0") or "").strip().lower()
    return val in {"1", "true", "yes", "y", "on"}


def _call_openai_cv_parser_structured(resume_text: str) -> dict | None:
    api_key = str(os.getenv("OPENAI_API_KEY", "") or "").strip()
    if not api_key:
        return None

    model = str(os.getenv("CAIQ_LLM_MODEL", "gpt-4.1-mini") or "gpt-4.1-mini").strip()
    timeout_s = float(os.getenv("CAIQ_LLM_TIMEOUT_S", "25") or "25")

    system_prompt = (
        "You are a strict CV parser for data-career guidance. "
        "Return ONLY valid JSON following the schema. "
        "Do not infer data-related master unless title/context clearly indicates data/AI/ML/analytics/computer science/statistics."
    )
    user_prompt = (
        "Parse this CV text and classify education and profile signals.\n"
        "CV_TEXT:\n" + str(resume_text or "")[:22000]
    )

    schema = {
        "type": "object",
        "properties": {
            "highest_education_level": {"type": "string", "enum": ["none", "bachelor", "master", "phd"]},
            "has_master_degree": {"type": "boolean"},
            "has_data_related_master": {"type": "boolean"},
            "education_data_relevance": {"type": "number", "minimum": 0, "maximum": 1},
            "inferred_seniority": {"type": "string", "enum": ["student_intern", "junior", "mid_level", "senior", "lead_manager"]},
            "skills_detected_additional": {"type": "array", "items": {"type": "string"}},
            "skills_evidence_overrides": {
                "type": "object",
                "additionalProperties": {"type": "string", "enum": ["professional", "project", "academic", "declared"]}
            },
            "confidence": {"type": "number", "minimum": 0, "maximum": 1},
            "reason": {"type": "string"}
        },
        "required": [
            "highest_education_level",
            "has_master_degree",
            "has_data_related_master",
            "education_data_relevance",
            "confidence"
        ],
        "additionalProperties": False
    }

    payload = {
        "model": model,
        "temperature": 0.0,
        "messages": [
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": user_prompt},
        ],
        "response_format": {
            "type": "json_schema",
            "json_schema": {
                "name": "cv_parser_output",
                "strict": True,
                "schema": schema,
            },
        },
    }

    try:
        r = requests.post(
            "https://api.openai.com/v1/chat/completions",
            headers={
                "Authorization": f"Bearer {api_key}",
                "Content-Type": "application/json",
            },
            json=payload,
            timeout=timeout_s,
        )
        if r.status_code != 200:
            return None
        data = r.json()
        content = data.get("choices", [{}])[0].get("message", {}).get("content", "")
        if not content:
            return None
        parsed = json.loads(content)
        if isinstance(parsed, dict):
            return parsed
    except Exception:
        return None
    return None


def _sanitize_llm_profile(llm: dict, taxonomy: dict) -> dict:
    out = {}
    if not isinstance(llm, dict):
        return out

    lvl = str(llm.get("highest_education_level", "none") or "none").strip().lower()
    if lvl in {"none", "bachelor", "master", "phd"}:
        out["highest_education_level"] = lvl

    if "has_master_degree" in llm:
        out["has_master_degree"] = bool(llm.get("has_master_degree"))
    if "has_data_related_master" in llm:
        out["has_data_related_master"] = bool(llm.get("has_data_related_master"))

    try:
        rel = float(llm.get("education_data_relevance", 0.0))
        out["education_data_relevance"] = float(max(0.0, min(1.0, rel)))
    except Exception:
        pass

    sen = str(llm.get("inferred_seniority", "") or "").strip().lower()
    if sen in {"student_intern", "junior", "mid_level", "senior", "lead_manager"}:
        out["inferred_seniority"] = sen

    add_sk = llm.get("skills_detected_additional", [])
    if isinstance(add_sk, list):
        valid = []
        tax_keys = set(str(k) for k in taxonomy.keys())
        for sk in add_sk:
            s = str(sk or "").strip().lower()
            if s in tax_keys:
                valid.append(s)
        out["skills_detected_additional"] = sorted(set(valid))

    over = llm.get("skills_evidence_overrides", {})
    if isinstance(over, dict):
        clean = {}
        tax_keys = set(str(k) for k in taxonomy.keys())
        for k, v in over.items():
            kk = str(k or "").strip().lower()
            vv = str(v or "").strip().lower()
            if kk in tax_keys and vv in {"professional", "project", "academic", "declared"}:
                clean[kk] = vv
        out["skills_evidence_overrides"] = clean

    try:
        out["confidence"] = float(max(0.0, min(1.0, float(llm.get("confidence", 0.0)))))
    except Exception:
        out["confidence"] = 0.0

    out["reason"] = str(llm.get("reason", "") or "").strip()[:500]
    return out


def _merge_rule_and_llm_profile(rule_profile: dict, llm_profile: dict, target_taxonomy: dict) -> dict:
    out = dict(rule_profile or {})
    llm = _sanitize_llm_profile(llm_profile or {}, target_taxonomy or {})
    llm_conf = float(llm.get("confidence", 0.0) or 0.0)

    out["parser_mode"] = "hybrid"
    out["llm_parser_used"] = bool(llm)
    out["llm_parser_confidence"] = llm_conf
    out["llm_parser_reason"] = str(llm.get("reason", "") or "")

    if not llm:
        out["parser_mode"] = "rule_based"
        return out

    # Validation disagreement tracking
    disagreements = []
    for k in ["has_master_degree", "has_data_related_master"]:
        if k in llm and k in out and bool(llm[k]) != bool(out[k]):
            disagreements.append(k)
    out["llm_disagreements"] = disagreements

    # Only override critical education fields with sufficient confidence
    if llm_conf >= 0.70:
        for k in ["highest_education_level", "has_master_degree", "has_data_related_master", "education_data_relevance"]:
            if k in llm:
                out[k] = llm[k]

    # Merge additional skills conservatively
    add_skills = set(llm.get("skills_detected_additional", []))
    base_skills = set(str(s) for s in out.get("skills_detected", []))
    merged_skills = sorted(base_skills | add_skills)
    out["skills_detected"] = merged_skills

    ev_map = dict(out.get("skills_evidence", {}) or {})
    for sk, ev in (llm.get("skills_evidence_overrides", {}) or {}).items():
        # only upgrade evidence if llm confidence is high
        if llm_conf >= 0.75:
            prev = str(ev_map.get(sk, "declared"))
            order = {"declared": 0, "academic": 1, "project": 2, "professional": 3}
            if order.get(ev, 0) >= order.get(prev, 0):
                ev_map[sk] = ev
    out["skills_evidence"] = ev_map

    return out


def build_candidate_profile_hybrid(resume_text: str, taxonomy: dict, use_llm: bool | None = None) -> dict:
    base = build_candidate_profile_from_resume(resume_text, taxonomy)

    if use_llm is None:
        use_llm = _env_flag("CAIQ_USE_LLM_PARSER", default=False)

    if not use_llm:
        base["parser_mode"] = "rule_based"
        base["llm_parser_used"] = False
        return base

    llm_raw = _call_openai_cv_parser_structured(resume_text)
    merged = _merge_rule_and_llm_profile(base, llm_raw or {}, taxonomy)
    return merged


def _coerce_embedding_matrix(x):
    try:
        from scipy import sparse
    except Exception:
        sparse = None

    if sparse is not None and sparse.issparse(x):
        return x.astype(np.float32)

    arr = np.asarray(x)
    if arr.dtype != object:
        return np.asarray(arr, dtype=np.float32)

    # Streamlit caching / fancy indexing can turn sparse rows or dense vectors
    # into dtype=object containers. Rebuild a proper numeric matrix first.
    if arr.ndim == 1:
        rows = list(arr)
    else:
        rows = [row for row in arr]

    if sparse is not None and rows and all(sparse.issparse(r) for r in rows):
        return sparse.vstack(rows).astype(np.float32)

    dense_rows = [np.asarray(r, dtype=np.float32).ravel() for r in rows]
    return np.vstack(dense_rows).astype(np.float32)


def cosine_similarity_matrix(a, b):
    a = _coerce_embedding_matrix(a)
    b = _coerce_embedding_matrix(b)

    try:
        from scipy import sparse
        from sklearn.metrics.pairwise import cosine_similarity

        if sparse.issparse(a) or sparse.issparse(b):
            return cosine_similarity(a, b)
    except Exception:
        pass

    a_norm = a / (np.linalg.norm(a, axis=1, keepdims=True) + 1e-9)
    b_norm = b / (np.linalg.norm(b, axis=1, keepdims=True) + 1e-9)
    return a_norm @ b_norm.T


# Cache global del modelo SentenceTransformer
# Se carga UNA sola vez por proceso y se reutiliza en todas las llamadas
_ST_MODEL_CACHE: dict = {}


# Modelo multilingüe (soporta ES + EN). Más robusto para CVs en español.
# Alternativa ligera en inglés: "all-MiniLM-L6-v2"
_DEFAULT_EMBED_MODEL = os.getenv("CAIQ_EMBED_MODEL", "paraphrase-multilingual-MiniLM-L12-v2")


def embed_texts(texts: list[str], model_name: str | None = None):
    # Try sentence-transformers first, fallback to TF-IDF.
    if model_name is None:
        model_name = _DEFAULT_EMBED_MODEL
    try:
        from sentence_transformers import SentenceTransformer

        # Usa el cache — no recarga el modelo si ya existe en memoria
        if model_name not in _ST_MODEL_CACHE:
            try:
                _ST_MODEL_CACHE[model_name] = SentenceTransformer(
                    model_name, local_files_only=True
                )
            except Exception:
                _ST_MODEL_CACHE[model_name] = SentenceTransformer(model_name)

        model = _ST_MODEL_CACHE[model_name]
        emb = model.encode(
            texts,
            show_progress_bar=False,
            convert_to_numpy=True,
            normalize_embeddings=False,
        )
        return emb, "sentence-transformers"
    except Exception:
        from sklearn.feature_extraction.text import TfidfVectorizer

        vec = TfidfVectorizer(max_features=40000, ngram_range=(1, 2))
        mat = vec.fit_transform(texts)
        return mat, "tfidf"


def _semantic_role_fit(
    skill_set: set[str],
    target_role: str,
    role_skills: list[str],
    demand_counts: dict[str, float],
) -> float:
    if not skill_set or not role_skills:
        return 0.0
    ranked_role_skills = sorted(role_skills, key=lambda s: float(demand_counts.get(s, 0.0)), reverse=True)[:25]
    candidate_txt = " ".join(sorted(skill_set))
    role_txt = f"{target_role.replace('_', ' ')} " + " ".join(ranked_role_skills)
    try:
        emb, _ = embed_texts([candidate_txt, role_txt])
        sim = float(cosine_similarity_matrix(emb[:1], emb[1:2]).ravel()[0])
        return float(max(0.0, min(1.0, (sim + 1.0) / 2.0)))
    except Exception:
        return 0.0


def _load_match_calibrator(calibration_path: str | Path | None = None) -> dict | None:
    global _MATCH_CALIBRATOR_CACHE
    if _MATCH_CALIBRATOR_CACHE is not None:
        return _MATCH_CALIBRATOR_CACHE
    if calibration_path is None:
        calibration_path = Path(__file__).resolve().parents[1] / "reports" / "match_calibration.json"
    p = Path(calibration_path)
    if not p.exists():
        _MATCH_CALIBRATOR_CACHE = None
        return None
    try:
        obj = json.loads(p.read_text(encoding="utf-8"))
        _MATCH_CALIBRATOR_CACHE = obj if isinstance(obj, dict) else None
    except Exception:
        _MATCH_CALIBRATOR_CACHE = None
    return _MATCH_CALIBRATOR_CACHE


def _apply_match_calibration(raw_score: float, target_role: str, calibrator: dict | None) -> float:
    v = float(max(0.0, min(1.0, raw_score)))
    if not calibrator or not bool(calibrator.get("enabled", False)):
        return v
    role_obj = ((calibrator.get("by_role", {}) or {}).get(target_role, {}) or {})
    x = role_obj.get("x")
    y = role_obj.get("y")
    if (not x or not y) and bool(calibrator.get("apply_global", False)):
        x = calibrator.get("x")
        y = calibrator.get("y")
    if not x or not y or len(x) < 2 or len(y) < 2:
        return v
    try:
        xv = np.array(x, dtype=float)
        yv = np.array(y, dtype=float)
        if xv.size != yv.size or xv.size < 2:
            return v
        out = float(np.interp(v, xv, yv))
        return float(max(0.0, min(1.0, out)))
    except Exception:
        return v


def tokenize_words(text: str) -> set[str]:
    return set(re.findall(r"[a-zA-Z]{3,}", norm_text(text).lower()))


def build_master_rerank_features(
    mdf: pd.DataFrame,
    ms: pd.DataFrame,
    gap_text: str,
) -> pd.DataFrame:
    feat = mdf.copy()
    skill_count_map = ms.groupby("master_id")["skill"].nunique().to_dict()
    feat["master_skill_count"] = feat["master_id"].map(skill_count_map).fillna(0).astype(float)
    feat["price_missing"] = feat["price_value_eur"].isna().astype(int)
    price_median = float(feat["price_value_eur"].dropna().median()) if feat["price_value_eur"].notna().any() else 0.0
    feat["price_filled"] = feat["price_value_eur"].fillna(price_median).astype(float)
    feat["study_len"] = feat["study_content"].fillna("").astype(str).str.len().astype(float)

    q_tokens = tokenize_words(gap_text)

    def lexical_overlap(text: str) -> float:
        t = tokenize_words(text)
        if not q_tokens or not t:
            return 0.0
        return len(q_tokens & t) / max(len(q_tokens), 1)

    feat["lexical_overlap"] = feat["master_text"].fillna("").astype(str).map(lexical_overlap).astype(float)
    feat["gap_ratio"] = feat["gap_coverage"] / np.maximum(feat["master_skill_count"], 1.0)
    feat["gap_ratio"] = feat["gap_ratio"].replace([np.inf, -np.inf], 0.0).fillna(0.0)
    return feat


def try_load_reranker_model(model_path: str):
