@functools.lru_cache(maxsize=16384)
def _learning_level_signal(text: str) -> float:
    low = _normalize_for_search(text)
    beginner = any(k in low for k in ["beginner", "intro", "introduction", "fundamentals", "basics", "starter", "for beginners"])
    advanced = any(k in low for k in ["advanced", "specialization", "expert", "professional", "masterclass", "hands-on project", "production"])
    if beginner and not advanced:
        return 0.25
    if advanced and not beginner:
        return 0.85
    if beginner and advanced:
        return 0.6
    return 0.55


def _desired_learning_level(candidate_profile: dict | None) -> float:
    if not candidate_profile:
        return 0.55
    stage = str(candidate_profile.get("career_stage", "growth_stage"))
    seniority = str(candidate_profile.get("inferred_seniority", "mid_level"))
    if stage == "early_career" or seniority in {"student_intern", "junior"}:
        return 0.4
    if stage == "advanced_stage" or seniority in {"senior", "lead_manager"}:
        return 0.75
    return 0.58


def _target_domain_gap_signal(target_role: str, candidate_profile: dict | None) -> float:
    if not candidate_profile:
        return 0.5
    domains = candidate_profile.get("experience_years_relevant_by_domain", {})
    role_domains = ROLE_DOMAIN_HINTS.get(target_role, set())
    if not role_domains:
        return 0.5
    vals = [float(domains.get(d, 0.0)) for d in role_domains]
    mean_exp = sum(vals) / max(len(vals), 1)
    # Lower experience in role-critical domains -> stronger upskilling need.
    return float(max(0.0, min(1.0, 1.0 - min(mean_exp, 6.0) / 6.0)))


def _compute_role_skill_bands(
    demand_df: pd.DataFrame,
    top_n: int = 40,
) -> tuple[dict[str, str], dict[str, float], list[str]]:
    """
    Build role-skill bands from market demand using frequency thresholds:
    - core:      freq >= 0.35
    - important: 0.15 <= freq < 0.35   (secondary)
    - complementary: freq < 0.15       (support)

    Returned demand weights are category weights:
    core=2.0, important=1.0, complementary=0.5
    """
    if demand_df is None or demand_df.empty:
        return {}, {}, []
    d = demand_df.copy()
    d = d.sort_values("demand_count", ascending=False).head(max(10, top_n)).copy()
    skills = d["skill_norm"].astype(str).tolist()
    n = len(skills)
    if n == 0:
        return {}, {}, []

    bands = {}
    if "demand_ratio" in d.columns:
        d["freq"] = pd.to_numeric(d["demand_ratio"], errors="coerce").fillna(0.0).clip(0.0, 1.0)
    else:
        vmax = float(pd.to_numeric(d["demand_count"], errors="coerce").fillna(0.0).max() or 0.0)
        if vmax > 0:
            d["freq"] = (pd.to_numeric(d["demand_count"], errors="coerce").fillna(0.0) / vmax).clip(0.0, 1.0)
        else:
            d["freq"] = 0.0

    for _, row in d.iterrows():
        sk = str(row["skill_norm"])
        f = float(row.get("freq", 0.0) or 0.0)
        if f >= 0.35:
            bands[sk] = "core"
        elif f >= 0.15:
            bands[sk] = "important"
        else:
            bands[sk] = "complementary"

    # Fallback when absolute market frequencies are very low due sparse extraction.
    # Reclassify using relative frequency scaling to preserve role separation.
    if not any(v == "core" for v in bands.values()):
        fmax = float(pd.to_numeric(d["freq"], errors="coerce").fillna(0.0).max() or 0.0)
        if fmax > 0.0:
            d["freq_rel"] = (pd.to_numeric(d["freq"], errors="coerce").fillna(0.0) / fmax).clip(0.0, 1.0)
            for _, row in d.iterrows():
                sk = str(row["skill_norm"])
                fr = float(row.get("freq_rel", 0.0) or 0.0)
                if fr >= 0.35:
                    bands[sk] = "core"
                elif fr >= 0.15:
                    bands[sk] = "important"
                else:
                    bands[sk] = "complementary"

    # Ensure minimum core density to avoid flat scores across roles.
    core_count = sum(1 for v in bands.values() if v == "core")
    if core_count == 0 and skills:
        min_core = min(max(3, int(round(0.15 * len(skills)))), max(6, len(skills)))
        for sk in skills[:min_core]:
            bands[sk] = "core"

    # Continuous demand weights: use actual demand_ratio instead of discrete 2/1/0.5.
    # Bands (core/important/complementary) are kept for display and band-level metrics,
    # but coverage scoring uses the real market gradient.
    freq_map = dict(zip(d["skill_norm"].astype(str), d["freq"].astype(float))) if "freq" in d.columns else {}
    demand_w = {}
    for sk, band in bands.items():
        dr = float(freq_map.get(sk, 0.0))
        if dr > 0.0:
            demand_w[sk] = max(0.1, min(2.0, dr * 2.0))
        else:
            # Fallback to discrete band weight when freq not available
            if band == "core":
                demand_w[sk] = 2.0
            elif band == "important":
                demand_w[sk] = 1.0
            else:
                demand_w[sk] = 0.5
    return bands, demand_w, skills


def _band_weight(band: str) -> float:
    if band == "core":
        return 2.0
    if band == "important":
        return 1.0
    return 0.5


def _band_rank(band: str) -> int:
    if band == "core":
        return 3
    if band == "important":
        return 2
    return 1


def _core_missing_penalty(core_cov: float, missing_core: int, core_total: int) -> float:
    # Progressive penalty: strong core coverage should not be over-penalized
    # by secondary misses.
    if core_total <= 0:
        return 1.0
    if core_cov >= 0.60:
        return 1.0
    if missing_core >= 4:
        return 0.82
    if missing_core >= 2:
        return 0.90
    if missing_core == 1:
        return 0.96
    return 1.0


def _derive_dynamic_combos(
    target_skills: list[str],
    role_bands: dict[str, str],
    demand_counts: dict[str, float],
) -> list[set[str]]:
    # Build combos from market-ranked skills for the role.
    if not target_skills:
        return []
    ranked = sorted(
        target_skills,
        key=lambda s: float(demand_counts.get(s, 0.0)),
        reverse=True,
    )
    core_ranked = [s for s in ranked if role_bands.get(s) == "core"]
    imp_ranked = [s for s in ranked if role_bands.get(s) == "important"]
    combos: list[set[str]] = []
    if len(core_ranked) >= 3:
        combos.append(set(core_ranked[:3]))
    if len(core_ranked) >= 2 and len(imp_ranked) >= 1:
        combos.append(set(core_ranked[:2] + imp_ranked[:1]))
    if len(core_ranked) >= 1 and len(imp_ranked) >= 2:
        combos.append(set(core_ranked[:1] + imp_ranked[:2]))
    if not combos and len(ranked) >= 3:
        combos.append(set(ranked[:3]))
    return combos


def _coverage_by_band(
    skill_set: set[str],
    role_skills: list[str],
    role_bands: dict[str, str],
    demand_w: dict[str, float],
) -> dict:
    out = {}
    for band in ["core", "important", "complementary", "optional"]:
        band_skills = [s for s in role_skills if role_bands.get(s) == band]
        denom = float(sum(float(demand_w.get(s, 1.0)) for s in band_skills))
        numer = float(sum(float(demand_w.get(s, 1.0)) for s in band_skills if s in skill_set))
        out[band] = float(numer / max(denom, 1.0))
        out[f"{band}_missing"] = sorted([s for s in band_skills if s not in skill_set])
        out[f"{band}_count"] = len(band_skills)
    return out


def _education_alignment_score(candidate_profile: dict | None, target_role: str) -> float:
    profile = candidate_profile or {}
    edu_rel = float((profile.get("education_relevance_by_role", {}) or {}).get(target_role, profile.get("education_data_relevance", 0.0)) or 0.0)
    has_data_master = bool(profile.get("has_data_related_master", False))
    has_master = bool(profile.get("has_master_degree", False))
    if has_data_master:
        return float(max(0.0, min(1.0, 0.75 + 0.25 * edu_rel)))
    if has_master:
        return float(max(0.0, min(1.0, 0.30 + 0.40 * edu_rel)))
    return float(max(0.0, min(1.0, 0.10 + 0.50 * edu_rel)))


def _experience_projects_score(candidate_profile: dict | None, target_role: str, role_skills: list[str]) -> float:
    profile = candidate_profile or {}
    domains = profile.get("experience_years_relevant_by_domain", {}) or {}
    role_domains = ROLE_DOMAIN_HINTS.get(target_role, set())
    role_domain_years = 0.0
    if role_domains:
        role_domain_years = sum(float(domains.get(d, 0.0)) for d in role_domains) / max(1, len(role_domains))
    exp_signal = min(1.0, role_domain_years / 3.0)
    evidence = {canonical_skill_name(k): str(v).strip().lower() for k, v in (profile.get("skills_evidence", {}) or {}).items()}
    role_set = set(role_skills)
    proj_or_prof = sum(1 for sk, ev in evidence.items() if sk in role_set and ev in {"professional", "project"})
    ev_signal = min(1.0, proj_or_prof / 5.0)
    return float(max(0.0, min(1.0, 0.65 * exp_signal + 0.35 * ev_signal)))


def _combo_bonus(skill_set: set[str], target_role: str, combos_override: list[set[str]] | None = None) -> float:
    combos = combos_override if combos_override is not None else ROLE_SKILL_COMBOS.get(target_role, [])
    if not combos:
        return 0.0
    hit = 0.0
    for c in combos:
        cset = {canonical_skill_name(s) for s in c}
        overlap = len(cset & skill_set) / max(len(cset), 1)
        if overlap >= 1.0:
            hit += 1.0
        elif overlap >= 0.67:
            hit += 0.55
        elif overlap >= 0.50:
            hit += 0.30
    return float(max(0.0, min(1.0, hit / max(1, len(combos)))))


def _seniority_target_from_text(text: str) -> int:
    low = _normalize_for_search(text)
    if any(k in low for k in ["intern", "trainee", "entry", "junior", "jr"]):
        return 1
    if any(k in low for k in ["lead", "principal", "head", "manager", "director"]):
        return 4
    if any(k in low for k in ["senior", "sr"]):
        return 3
    if any(k in low for k in ["mid", "intermediate"]):
        return 2
    return 2


def _seniority_fit_score(user_seniority: str, target_seniority_txt: str) -> float:
    u = SENIORITY_ORDER.get(user_seniority, 2)
    t = _seniority_target_from_text(target_seniority_txt)
    diff = abs(u - t)
    return float(max(0.0, min(1.0, 1.0 - 0.23 * diff)))


def select_courses_max_gap_coverage(
    courses_scored: pd.DataFrame,
    course_skills: pd.DataFrame,
    remaining_gap: set[str],
    skill_weight: dict[str, float] | None = None,
    max_courses: int = 12,
) -> pd.DataFrame:
    """
    Greedy set-cover style selector:
    1) maximize newly covered gap skills
    2) tie-break by course_score
    3) keep structure of courses_scored rows unchanged
    """
    if courses_scored is None or courses_scored.empty:
        return courses_scored
    if not remaining_gap:
        return courses_scored.sort_values("course_score", ascending=False).head(min(max_courses, len(courses_scored))).copy()

    cs = course_skills.copy()
    cs["skill"] = cs["skill"].astype(str)
    cs["skill_norm"] = cs["skill"].map(canonical_skill_name)
    cs = cs[cs["skill_norm"] != ""].copy()
    cands = courses_scored.copy()
    if "course_id" not in cands.columns:
        return cands.sort_values("course_score", ascending=False).head(min(max_courses, len(cands))).copy()

    course_skill_map = {}
    for cid, g in cs.groupby("course_id"):
        course_skill_map[cid] = set(g["skill_norm"].tolist())

    cands["course_score"] = pd.to_numeric(cands.get("course_score"), errors="coerce").fillna(0.0)
    cands = cands.sort_values("course_score", ascending=False).copy()

    uncovered = set(remaining_gap)
    weight_map = skill_weight or {}
    selected_ids: set[str] = set()
    selected_rows: list[dict] = []

    # Convert to list of dicts once — 5-10x faster than repeated iterrows()
    records = cands.to_dict("records")
    # Keep a parallel index list so we can reconstruct DataFrame rows
    orig_indices = list(cands.index)

    remaining_records = list(zip(orig_indices, records))

    for _ in range(min(max_courses, len(records))):
        if not remaining_records:
            break
        best_pos = None
        best_new_weight = -1.0
        best_new = -1
        best_score = -1.0

        for pos, (_, rec) in enumerate(remaining_records):
            cid = rec.get("course_id")
            skills = course_skill_map.get(cid, set())
            newly_skills = skills & uncovered
            newly = len(newly_skills)
            newly_weight = float(sum(float(weight_map.get(s, 1.0)) for s in newly_skills))
            score = float(rec.get("course_score", 0.0) or 0.0)
            if best_pos is None:
                best_pos = pos
                best_new = newly
                best_score = score
                best_new_weight = newly_weight
                continue
            if (
                (newly_weight > best_new_weight + 1e-9)
                or (abs(newly_weight - best_new_weight) <= 1e-9 and newly > best_new)
                or (abs(newly_weight - best_new_weight) <= 1e-9 and newly == best_new and score > best_score)
            ):
                best_pos = pos
                best_new = newly
                best_score = score
                best_new_weight = newly_weight

        if best_pos is None:
            break
        _, best_rec = remaining_records.pop(best_pos)
        cid = best_rec.get("course_id")
        selected_ids.add(cid)
        selected_rows.append(best_rec)
        uncovered -= course_skill_map.get(cid, set())
        if not uncovered:
            break

    selected_df = pd.DataFrame(selected_rows)
    if len(selected_df) < max_courses:
        remaining_df = cands[~cands["course_id"].isin(selected_ids)].head(max_courses - len(selected_df))
        selected_df = pd.concat([selected_df, remaining_df], ignore_index=True)

    return selected_df.head(max_courses).copy()


# Module-level cache: keyed on (id(skills_df), id(features_df), id_col)
# DataFrames loaded via @st.cache_data are the same object in memory across calls,
# so id() is stable. This avoids re-running extract_skills on ~3000 items every call.
_AUGMENT_CACHE: dict = {}


def _augment_item_skills_with_taxonomy(
    skills_df: pd.DataFrame,
    features_df: pd.DataFrame,
    id_col: str,
    text_cols: list[str],
    taxonomy: dict | None,
) -> pd.DataFrame:
    """
    Keep original curated mappings and append inferred mappings from text
    when taxonomy is available. This increases catalog coverage without
    changing dataset structure on disk.

    Results are cached in _AUGMENT_CACHE keyed on object identity so that
    repeated calls with the same DataFrames (common in Streamlit sessions)
    return instantly instead of re-running extract_skills on every item.
    """
    cache_key = (id(skills_df), id(features_df), id_col)
    if cache_key in _AUGMENT_CACHE:
        return _AUGMENT_CACHE[cache_key]

    raw = skills_df.copy()
    # Use ALL rows (including sentinels) to build the "already processed" set.
    # Sentinel rows with skill=="__none__" mark items that were processed but
    # had no taxonomy matches — they must be skipped to avoid re-running extract_skills.
    all_ids_in_file = set(raw[id_col].dropna().tolist()) if id_col in raw.columns else set()
    # Strip sentinels before building the clean base that will be returned.
    if "skill" in raw.columns:
        sentinel_vals = {"__none__", ""}
        base = raw[~raw["skill"].fillna("").astype(str).isin(sentinel_vals)].copy()
    else:
        base = raw.copy()
    if taxonomy is None or not isinstance(taxonomy, dict) or not len(taxonomy):
        _AUGMENT_CACHE[cache_key] = base
        return base
    if id_col not in features_df.columns:
        _AUGMENT_CACHE[cache_key] = base
        return base

    # existing_ids = all IDs that were already handled (including no-match sentinels)
    existing_ids = all_ids_in_file
    rows = []
    view = features_df[[id_col] + [c for c in text_cols if c in features_df.columns]].copy()
    view = view.dropna(subset=[id_col]).drop_duplicates(subset=[id_col])
    # Use to_dict for faster iteration than iterrows
    for rec in view.to_dict("records"):
        item_id = rec.get(id_col)
        if item_id in existing_ids:
            continue
        text = " ".join(str(rec.get(c, "") or "") for c in text_cols)
        inferred = extract_skills(text, taxonomy)
        for sk in inferred:
            rows.append({id_col: item_id, "skill": sk})
    if not rows:
        _AUGMENT_CACHE[cache_key] = base
        return base
    add = pd.DataFrame(rows)
    out = pd.concat([base, add], ignore_index=True)
    # Remove sentinel rows used as "already processed" markers
    if "skill" in out.columns:
        out = out[out["skill"].fillna("").astype(str) != "__none__"]
    out = out.drop_duplicates(subset=[id_col, "skill"])
    _AUGMENT_CACHE[cache_key] = out
    return out

def detect_best_current_role(
    candidate_profile: dict,
    data: dict,
    all_roles: list | None = None,
) -> dict:
    all_roles = all_roles or [
        "ml_engineer",
        "data_scientist",
        "data_engineer",
        "data_analyst",
        "other_data_role",
    ]
    role_skill_demand = (data or {}).get("role_skill_demand")
    if role_skill_demand is None or getattr(role_skill_demand, "empty", True):
        return {
            "detected_best_role": "",
            "detected_best_role_score": 0,
            "role_scores_all": {},
        }

    profile = candidate_profile or {}
    explicit = profile.get("skills_detected_explicit", []) or []
    detected = profile.get("skills_detected", []) or []
    inferred = profile.get("inferred_skills", []) or []
    candidate_skills_norm = {
        canonical_skill_name(s)
        for s in list(explicit) + list(detected) + list(inferred)
        if canonical_skill_name(s)
    }
    if not candidate_skills_norm:
        return {
            "detected_best_role": "",
            "detected_best_role_score": 0,
            "role_scores_all": {role: 0 for role in all_roles},
        }

    role_scores_all = {}
    for role in all_roles:
        demand = role_skill_demand[role_skill_demand["role_family"].astype(str).str.lower() == str(role).lower()].copy()
        if demand.empty:
            role_scores_all[role] = 0
            continue

        demand["skill"] = demand["skill"].astype(str)
        demand["skill_norm"] = demand["skill"].map(canonical_skill_name)
        demand = demand[demand["skill_norm"] != ""].copy()
        agg_cols = ["demand_count"]
        if "demand_ratio" in demand.columns:
            agg_cols.append("demand_ratio")
        demand = demand.groupby(["skill_norm"], as_index=False)[agg_cols].max()
        demand = demand.sort_values("demand_count", ascending=False)

        role_bands, demand_w_market, target_skills_all = _compute_role_skill_bands(demand, top_n=40)
        demand_counts = {}
        for _, r in demand.iterrows():
            sk = str(r.get("skill_norm", "")).strip()
            if not sk:
                continue
            demand_counts[sk] = float(r.get("demand_count", 0.0) or 0.0)

        skill_weight = {}
        target_skills = list(target_skills_all)
        if not target_skills:
            target_skills = [str(s) for s in demand["skill_norm"].astype(str).head(40).tolist()]
        target_skills = sorted(set([s for s in target_skills if s]))
        for sk in target_skills:
            skill_weight[sk] = _band_weight(role_bands.get(sk, "complementary"))

        priors = ROLE_PRIOR_SKILLS.get(role, {})
        prior_core = [canonical_skill_name(s) for s in priors.get("core", []) if canonical_skill_name(s)]
        prior_important = [canonical_skill_name(s) for s in priors.get("important", []) if canonical_skill_name(s)]
        market_core_count = sum(1 for s in target_skills if role_bands.get(s) == "core")
        market_imp_count = sum(1 for s in target_skills if role_bands.get(s) == "important")
        use_priors = not (
            market_core_count >= MIN_MARKET_CORE_FOR_NO_PRIOR
            and market_imp_count >= MIN_MARKET_IMPORTANT_FOR_NO_PRIOR
        )
        for sk in prior_core:
            if not use_priors and sk not in target_skills:
                continue
            if use_priors and sk not in target_skills:
                target_skills.append(sk)
            prev = role_bands.get(sk, "complementary")
            if _band_rank("core") >= _band_rank(prev):
                role_bands[sk] = "core"
            skill_weight[sk] = max(float(skill_weight.get(sk, 0.0)), 2.0)
            demand_w_market[sk] = max(float(demand_w_market.get(sk, 0.0)), 2.0)
        for sk in prior_important:
            if not use_priors and sk not in target_skills:
                continue
            if use_priors and sk not in target_skills:
                target_skills.append(sk)
            prev = role_bands.get(sk, "complementary")
            if _band_rank("important") >= _band_rank(prev):
                role_bands[sk] = "important"
            skill_weight[sk] = max(float(skill_weight.get(sk, 0.0)), 1.0)
            demand_w_market[sk] = max(float(demand_w_market.get(sk, 0.0)), 1.0)

        target_skills = sorted(set(target_skills))
        target_set = set(target_skills)
        if not target_set:
            role_scores_all[role] = 0
            continue

        current_cov = _coverage_by_band(candidate_skills_norm, target_skills, role_bands, demand_w_market)
        target_total_weight = float(sum(float(skill_weight.get(sk, 0.1)) for sk in target_set))
        present_weight = float(sum(float(skill_weight.get(sk, 0.1)) for sk in (target_set & candidate_skills_norm)))
        base_now = float(present_weight / max(target_total_weight, 1e-9))
        core_missing_now = len(current_cov.get("core_missing", []) or [])
        penalty_now = _core_missing_penalty(
            core_cov=float(current_cov.get("core", 0.0)),
            missing_core=core_missing_now,
            core_total=int(current_cov.get("core_count", 0) or 0),
        )
        structural_now = (
            float(MATCH_COMPONENT_WEIGHTS["weighted_presence"]) * base_now
            + float(MATCH_COMPONENT_WEIGHTS["core_coverage"]) * float(current_cov.get("core", 0.0))
            + float(MATCH_COMPONENT_WEIGHTS["important_coverage"]) * float(current_cov.get("important", 0.0))
            + float(MATCH_COMPONENT_WEIGHTS["complementary_coverage"]) * float(current_cov.get("complementary", 0.0))
        )
        structural_now = structural_now / 0.90
        score_pct = int(round(100.0 * max(0.0, min(1.0, structural_now * penalty_now))))
        role_scores_all[role] = score_pct

    for role in list(role_scores_all.keys()):
        signatures = SIGNATURE_SKILLS.get(role, set())
        if not signatures:
            continue
        has_signature = bool(candidate_skills_norm & signatures)
        if not has_signature:
            role_scores_all[role] = int(round(role_scores_all[role] * 0.4))

    if role_scores_all:
        max_score = max(role_scores_all.values())
        if max_score > 0:
            n_skills = len(profile.get("skills_detected_explicit", []) or [])
            if n_skills <= 2:
                max_cap = 35
            elif n_skills <= 5:
                max_cap = 55
            elif n_skills <= 9:
                max_cap = 72
            else:
                max_cap = 85
            scale_factor = max_cap / max_score
            scale_factor = min(scale_factor, 1.8)
            role_scores_all = {
                role: int(round(min(score * scale_factor, max_cap)))
                for role, score in role_scores_all.items()
            }

    best_role = max(role_scores_all.items(), key=lambda kv: kv[1])[0] if role_scores_all else ""
    best_score = int(role_scores_all.get(best_role, 0) or 0)
    return {
        "detected_best_role": best_role,
        "detected_best_role_score": best_score,
        "role_scores_all": role_scores_all,
    }


def recommend_learning_path(
    candidate_skills: set[str],
    target_role: str,
    role_skill_demand: pd.DataFrame,
    masters_feat: pd.DataFrame,
    master_skills: pd.DataFrame,
    courses_feat: pd.DataFrame,
    course_skills: pd.DataFrame,
    filters: dict,
    weight_coverage: float = 0.65,
    weight_semantic: float = 0.35,
    master_reranker_model=None,
    reranker_blend: float = 0.7,
    candidate_profile: dict | None = None,
    taxonomy: dict | None = None,
    core_threshold: float = 0.15,
    catalog_embeddings: dict | None = None,
):
    candidate_skills_norm = {canonical_skill_name(s) for s in (candidate_skills or set()) if canonical_skill_name(s)}
    profile_skill_weights_raw = (candidate_profile or {}).get("candidate_skill_weight_map", {}) or {}
    profile_skill_weights = {}
    for k, v in profile_skill_weights_raw.items():
        ck = canonical_skill_name(k)
        if not ck:
            continue
        try:
            profile_skill_weights[ck] = float(max(0.4, min(1.0, float(v))))
        except Exception:
            continue

    def _cand_skill_weight(sk: str) -> float:
        return float(profile_skill_weights.get(sk, 1.0))
    demand = role_skill_demand[role_skill_demand["role_family"].str.lower() == target_role.lower()].copy()
    if demand.empty:
        demand = role_skill_demand.copy()

    demand["skill"] = demand["skill"].astype(str)
    demand["skill_norm"] = demand["skill"].map(canonical_skill_name)
    demand = demand[demand["skill_norm"] != ""].copy()
    agg_cols = ["demand_count"]
    if "demand_ratio" in demand.columns:
        agg_cols.append("demand_ratio")
    demand = demand.groupby(["skill_norm"], as_index=False)[agg_cols].max()
    demand = demand.sort_values("demand_count", ascending=False)
    role_bands, demand_w_market, target_skills_all = _compute_role_skill_bands(demand, top_n=40)
    demand_counts = {}
    demand_ratios = {}
    for _, r in demand.iterrows():
        sk = str(r.get("skill_norm", "")).strip()
        if not sk:
            continue
        demand_counts[sk] = float(r.get("demand_count", 0.0) or 0.0)
        if "demand_ratio" in demand.columns:
            demand_ratios[sk] = float(r.get("demand_ratio", 0.0) or 0.0)
    # Market-driven skill weights by level:
    # Weighted coverage: continuous demand_ratio instead of discrete bands (2.0/1.0/0.5).
    # This captures the real market gradient — Python at 0.85 demand_ratio is not
    # interchangeable with Tableau at 0.22, even if both are "core" band.
    # Scale: demand_ratio in [0,1] → skill_weight in [0.1, 2.0] (preserves band range).
    skill_weight = {}
    target_skills = list(target_skills_all)
    if "demand_ratio" in demand.columns:
        core_skills = [str(r.get("skill_norm", "")).strip() for _, r in demand.iterrows() if float(r.get("demand_ratio", 0.0) or 0.0) >= float(core_threshold)]
    else:
        core_skills = []
    # Use all role skills for matching, but prefer top-N to limit noise.
    if not target_skills:
        target_skills = [str(s) for s in demand["skill_norm"].astype(str).head(40).tolist()]
    target_skills = [s for s in target_skills if s]
    target_skills = sorted(set(target_skills))
    for sk in target_skills:
        dr = demand_ratios.get(sk, 0.0)
        if dr > 0.0:
            # Continuous weight: scale [0,1] demand_ratio → [0.1, 2.0]
            skill_weight[sk] = max(0.1, min(2.0, dr * 2.0))
        else:
            # Fallback to discrete band weight when demand_ratio unavailable
            skill_weight[sk] = _band_weight(role_bands.get(sk, "complementary"))

    # Blend market demand with role priors only when market signal is sparse.
    priors = ROLE_PRIOR_SKILLS.get(target_role, {})
    prior_core = [canonical_skill_name(s) for s in priors.get("core", []) if canonical_skill_name(s)]
    prior_important = [canonical_skill_name(s) for s in priors.get("important", []) if canonical_skill_name(s)]
    market_core_count = sum(1 for s in target_skills if role_bands.get(s) == "core")
    market_imp_count = sum(1 for s in target_skills if role_bands.get(s) == "important")
    use_priors = not (
        market_core_count >= MIN_MARKET_CORE_FOR_NO_PRIOR
        and market_imp_count >= MIN_MARKET_IMPORTANT_FOR_NO_PRIOR
    )
    for sk in prior_core:
        if not use_priors and sk not in target_skills:
            continue
        if use_priors and sk not in target_skills:
            target_skills.append(sk)
        prev = role_bands.get(sk, "complementary")
        if _band_rank("core") >= _band_rank(prev):
            role_bands[sk] = "core"
        skill_weight[sk] = max(float(skill_weight.get(sk, 0.0)), 2.0)
        demand_w_market[sk] = max(float(demand_w_market.get(sk, 0.0)), 2.0)
    for sk in prior_important:
        if not use_priors and sk not in target_skills:
            continue
        if use_priors and sk not in target_skills:
            target_skills.append(sk)
        prev = role_bands.get(sk, "complementary")
        if _band_rank("important") >= _band_rank(prev):
            role_bands[sk] = "important"
        skill_weight[sk] = max(float(skill_weight.get(sk, 0.0)), 1.0)
        demand_w_market[sk] = max(float(demand_w_market.get(sk, 0.0)), 1.0)
    target_skills = sorted(set(target_skills))
    target_set = set(target_skills)
    dynamic_combos = _derive_dynamic_combos(target_skills, role_bands, demand_counts)

    gap = sorted(
        target_set - candidate_skills_norm,
        key=lambda s: (-float(demand_ratios.get(s, 0.0)), -float(demand_counts.get(s, 0.0)), str(s)),
    )
    gap_set = set(gap)
    target_total_weight = float(sum(float(skill_weight.get(sk, 0.1)) for sk in target_set))
    present_weight = float(sum(float(skill_weight.get(sk, 0.1)) * _cand_skill_weight(sk) for sk in (target_set & candidate_skills_norm)))
    role_match_ratio_weighted = float(present_weight / max(target_total_weight, 1.0))
    current_cov = _coverage_by_band(candidate_skills_norm, target_skills, role_bands, demand_w_market)
    missing_core_skills = current_cov.get("core_missing", []) or []
    missing_important_skills = current_cov.get("important_missing", []) or []
    role_fit = detect_best_current_role(
        candidate_profile,
        {"role_skill_demand": role_skill_demand},
    )

    # Apply filters
    m = masters_feat.copy()
    if filters.get("max_price") is not None:
        m = m[(m["price_value_eur"].isna()) | (m["price_value_eur"] <= filters["max_price"])]
    if filters.get("location"):
        loc = filters["location"].lower()
        m = m[m["location"].fillna("").str.lower().str.contains(loc, na=False)]
    if filters.get("study_keyword"):
        kw = filters["study_keyword"].lower()
        m = m[m["study_content"].fillna("").str.lower().str.contains(kw, na=False)]

    # Coverage score
    ms = _augment_item_skills_with_taxonomy(
        skills_df=master_skills,
        features_df=masters_feat,
        id_col="master_id",
        text_cols=["program_name", "study_content", "master_text"],
        taxonomy=taxonomy,
    )
    ms["skill"] = ms["skill"].astype(str)
    ms["skill_norm"] = ms["skill"].map(canonical_skill_name)
    ms = ms[ms["skill_norm"] != ""].copy()
    master_cov = []
    for mid, g in ms.groupby("master_id"):
        sset = set(g["skill_norm"].tolist())
        overlap = sset & gap_set
        cov = len(overlap)
        cov_w = float(sum(float(skill_weight.get(sk, 0.1)) for sk in overlap))
        master_cov.append((mid, cov, cov_w, sset))
    cov_df = pd.DataFrame(master_cov, columns=["master_id", "gap_coverage", "gap_coverage_weighted", "skill_set"])
    m = m.merge(cov_df[["master_id", "gap_coverage", "gap_coverage_weighted"]], on="master_id", how="left").fillna({"gap_coverage": 0, "gap_coverage_weighted": 0.0})

    # Semantic score for masters
    gap_text = " ".join(gap) if gap else " ".join(target_skills)
    m_texts = m["master_text"].fillna("").astype(str).tolist()
    if m_texts:
        cached_master_emb = None
        emb_mode = "none"
        master_vectorizer = None
        if catalog_embeddings and "master_embeddings" in catalog_embeddings:
            master_id_to_idx = catalog_embeddings.get("master_id_to_idx", {}) or {}
            idxs = []
            for mid in m["master_id"].tolist():
                idx = master_id_to_idx.get(str(mid))
                if idx is None:
                    idxs = []
                    break
                idxs.append(idx)
            if idxs:
                cached_master_emb = catalog_embeddings["master_embeddings"][idxs]
                emb_mode = str(catalog_embeddings.get("master_emb_mode", "cached") or "cached")
                master_vectorizer = catalog_embeddings.get("master_vectorizer")
        if cached_master_emb is not None:
            if emb_mode == "tfidf" and master_vectorizer is not None:
                gap_emb = master_vectorizer.transform([gap_text])
            else:
                gap_emb, _ = embed_texts([gap_text])
            sim = cosine_similarity_matrix(gap_emb, cached_master_emb).ravel()
            m["semantic_score"] = sim
        else:
            emb, emb_mode = embed_texts([gap_text] + m_texts)
            sim = cosine_similarity_matrix(emb[:1], emb[1:]).ravel()
            m["semantic_score"] = sim
    else:
        emb_mode = "none"
        m["semantic_score"] = 0.0

    max_cov = max(float(m["gap_coverage_weighted"].max()), 1.0) if len(m) else 1.0
    m["coverage_score"] = m["gap_coverage_weighted"] / max_cov
    m["master_score"] = weight_coverage * m["coverage_score"] + weight_semantic * m["semantic_score"]
    if candidate_profile:
        desired = _desired_learning_level(candidate_profile)
        role_gap_need = _target_domain_gap_signal(target_role, candidate_profile)
        m_level = m["program_name"].fillna("").astype(str) + " " + m["study_content"].fillna("").astype(str)
        m["level_signal"] = m_level.map(_learning_level_signal).astype(float)
        m["level_fit"] = 1.0 - (m["level_signal"] - desired).abs()
        m["level_fit"] = m["level_fit"].clip(0.0, 1.0)
        # If role-domain experience is low, prioritize stronger role-oriented masters.
        m["master_score"] = 0.86 * m["master_score"] + 0.10 * m["level_fit"] + 0.04 * role_gap_need
        # Avoid recommending a near-duplicate master when user already has a data-related one.
        has_data_master = bool(candidate_profile.get("has_data_related_master", False))
        candidate_master_focus = set(candidate_profile.get("master_focus_tags", []) or [])
        role_focus = ROLE_PREFERRED_MASTER_FOCUS.get(target_role, {"data_science"})
        m_text = (
            m["program_name"].fillna("").astype(str)
            + " "
            + m["study_content"].fillna("").astype(str)
            + " "
            + m["master_text"].fillna("").astype(str)
        )
        m["program_focus_tags"] = m_text.map(infer_master_focus_tags)
        m["program_focus_primary"] = m["program_focus_tags"].map(lambda tags: tags[0] if tags else "unknown")
        m["program_role_focus_fit"] = m["program_focus_tags"].map(
            lambda tags: 1.0 if (set(tags) & role_focus) else 0.0
        ).astype(float)
        if has_data_master and candidate_master_focus:
            m["same_as_existing_master_focus"] = m["program_focus_tags"].map(
                lambda tags: 1.0 if (set(tags) & candidate_master_focus) else 0.0
            ).astype(float)
            # Penalty for same-focus master, boost for role-fit but different focus.
            m["master_score"] = (
                m["master_score"].astype(float)
                - 0.18 * m["same_as_existing_master_focus"].astype(float)
                + 0.06 * ((1.0 - m["same_as_existing_master_focus"].astype(float)) * m["program_role_focus_fit"].astype(float))
            )
            m["master_score"] = m["master_score"].clip(lower=0.0, upper=1.0)

    # Optional supervised reranking for masters.
    m["reranker_score"] = np.nan
    if master_reranker_model is not None and len(m):
        feat = build_master_rerank_features(m, ms, gap_text)
        cols = [
            "coverage_score",
            "semantic_score",
            "gap_coverage",
            "master_skill_count",
            "price_missing",
            "price_filled",
            "study_len",
            "lexical_overlap",
            "gap_ratio",
        ]
        x = feat[cols].fillna(0.0).to_numpy()
        try:
            pred = master_reranker_model.predict(x)
            pmin = float(np.min(pred))
            pmax = float(np.max(pred))
            if pmax > pmin:
                pred = (pred - pmin) / (pmax - pmin)
            else:
                pred = np.zeros_like(pred)
            m["reranker_score"] = pred
            blend = min(max(float(reranker_blend), 0.0), 1.0)
            m["master_score"] = (1.0 - blend) * m["master_score"] + blend * m["reranker_score"]
        except Exception:
            pass

    m = m.sort_values("master_score", ascending=False)
    top_masters = m.head(5).copy()
    if candidate_profile and bool(candidate_profile.get("has_data_related_master", False)):
        candidate_master_focus = set(candidate_profile.get("master_focus_tags", []) or [])
        if candidate_master_focus and "program_focus_tags" in m.columns:
            # Prefer non-redundant masters if there are enough alternatives.
            non_redundant = m[
                ~m["program_focus_tags"].map(lambda tags: bool(set(tags) & candidate_master_focus))
            ].copy()
            if len(non_redundant) >= 3:
                top_masters = non_redundant.head(5).copy()
            elif len(non_redundant) > 0:
                head_non_redundant = non_redundant.head(3).copy()
                remaining = m[~m["master_id"].astype(str).isin(set(head_non_redundant["master_id"].astype(str)))]
                top_masters = pd.concat([head_non_redundant, remaining.head(max(0, 5 - len(head_non_redundant)))], ignore_index=True)

    # Re-ranking by priority gaps
    core_skills = set(
        canonical_skill_name(s)
        for s in (missing_core_skills or [])
        if canonical_skill_name(s)
    )
    important_skills = set(
        canonical_skill_name(s)
        for s in (missing_important_skills or [])
        if canonical_skill_name(s)
    )

    if core_skills or important_skills:
        master_skill_map = {}
        for mid, g in ms.groupby("master_id"):
            master_skill_map[mid] = set(g["skill_norm"].tolist())

        def _master_boost(row):
            covered = master_skill_map.get(row.get("master_id", ""), set())
            return (
                len(covered & core_skills) * 3 +
                len(covered & important_skills) * 1
            )

        master_ranked = m.copy()
        master_ranked["_boost"] = master_ranked.apply(_master_boost, axis=1)
        if int(pd.to_numeric(master_ranked["_boost"], errors="coerce").fillna(0).max()) > 0:
            top_masters = master_ranked.sort_values(
                ["_boost", "master_score"],
                ascending=[False, False]
            ).head(5).copy()
        top_masters = top_masters.drop(columns=["_boost"], errors="ignore")

    # Remaining gap after masters
    covered_by_masters = set()
    for mid in top_masters["master_id"].tolist():
        s = ms.loc[ms["master_id"] == mid, "skill_norm"].astype(str).tolist()
        covered_by_masters.update(s)
    remaining_gap = sorted(
        gap_set - covered_by_masters,
        key=lambda s: (-float(demand_ratios.get(s, 0.0)), -float(demand_counts.get(s, 0.0)), str(s)),
    )
    rem_set = set(remaining_gap)

    cs = _augment_item_skills_with_taxonomy(
        skills_df=course_skills,
        features_df=courses_feat,
        id_col="course_id",
        text_cols=["title", "course_text"],
        taxonomy=taxonomy,
    )
    cs["skill"] = cs["skill"].astype(str)
    cs["skill_norm"] = cs["skill"].map(canonical_skill_name)
    cs = cs[cs["skill_norm"] != ""].copy()
    course_cov = []
    for cid, g in cs.groupby("course_id"):
        sset = set(g["skill_norm"].tolist())
        overlap = sset & rem_set
        cov = len(overlap)
        cov_w = float(sum(float(skill_weight.get(sk, 0.1)) for sk in overlap))
        course_cov.append((cid, cov, cov_w))
    c_cov_df = pd.DataFrame(course_cov, columns=["course_id", "remaining_gap_coverage", "remaining_gap_coverage_weighted"])

    c = courses_feat.merge(c_cov_df, on="course_id", how="left").fillna({"remaining_gap_coverage": 0, "remaining_gap_coverage_weighted": 0.0})
    c_texts = c["course_text"].fillna("").astype(str).tolist()
    c_query = " ".join(remaining_gap) if remaining_gap else gap_text
    if c_texts:
        cached_course_emb = None
        course_mode = "none"
        course_vectorizer = None
        if catalog_embeddings and "course_embeddings" in catalog_embeddings:
            course_id_to_idx = catalog_embeddings.get("course_id_to_idx", {}) or {}
            idxs = []
            for cid in c["course_id"].tolist():
                idx = course_id_to_idx.get(str(cid))
                if idx is None:
                    idxs = []
                    break
                idxs.append(idx)
            if idxs:
                cached_course_emb = catalog_embeddings["course_embeddings"][idxs]
                course_mode = str(catalog_embeddings.get("course_emb_mode", "cached") or "cached")
                course_vectorizer = catalog_embeddings.get("course_vectorizer")
        if cached_course_emb is not None:
            if course_mode == "tfidf" and course_vectorizer is not None:
                q_emb = course_vectorizer.transform([c_query])
            else:
                q_emb, _ = embed_texts([c_query])
            c_sim = cosine_similarity_matrix(q_emb, cached_course_emb).ravel()
            c["semantic_score"] = c_sim
        else:
            c_emb, _ = embed_texts([c_query] + c_texts)
            c_sim = cosine_similarity_matrix(c_emb[:1], c_emb[1:]).ravel()
            c["semantic_score"] = c_sim
    else:
        c["semantic_score"] = 0.0

    max_c_cov = max(float(c["remaining_gap_coverage_weighted"].max()), 1.0) if len(c) else 1.0
    c["coverage_score"] = c["remaining_gap_coverage_weighted"] / max_c_cov
    c["course_score"] = weight_coverage * c["coverage_score"] + weight_semantic * c["semantic_score"]
    if candidate_profile:
        desired = _desired_learning_level(candidate_profile)
        role_gap_need = _target_domain_gap_signal(target_role, candidate_profile)
        c_level_text = c["title"].fillna("").astype(str) + " " + c["course_text"].fillna("").astype(str)
        c["level_signal"] = c_level_text.map(_learning_level_signal).astype(float)
        c["level_fit"] = 1.0 - (c["level_signal"] - desired).abs()
        c["level_fit"] = c["level_fit"].clip(0.0, 1.0)
        # Stronger adaptation for courses to avoid over-basic suggestions for experienced profiles.
        c["course_score"] = 0.82 * c["course_score"] + 0.12 * c["level_fit"] + 0.06 * role_gap_need
    # Select courses prioritizing gap closure (set-cover), then quality score.
    top_courses = select_courses_max_gap_coverage(
        courses_scored=c,
        course_skills=cs,
        remaining_gap=rem_set,
        skill_weight=skill_weight,
        max_courses=12,
    )

    # Re-ranking by priority gaps
    if core_skills or important_skills:
        cmap = {}
        for cid, g in cs.groupby("course_id"):
            cmap[cid] = set(g["skill_norm"].tolist())

        def _course_boost(row):
            covered = cmap.get(row.get("course_id", ""), set())
            core_topics_hit = {SKILL_TOPIC_MAP.get(s, s) for s in (covered & core_skills)}
            important_topics_hit = {SKILL_TOPIC_MAP.get(s, s) for s in (covered & important_skills)}
            return len(core_topics_hit) * 3 + len(important_topics_hit) * 1

        course_ranked = c.copy()
        course_ranked["_boost"] = course_ranked.apply(_course_boost, axis=1)
        if int(pd.to_numeric(course_ranked["_boost"], errors="coerce").fillna(0).max()) > 0:
            course_ranked = course_ranked.sort_values(
                ["_boost", "course_score"],
                ascending=[False, False]
            ).copy()
        else:
            course_ranked = course_ranked.sort_values("course_score", ascending=False).copy()

        priority_topics_ordered = []
        seen_topics = set()
        for skill in list(core_skills) + list(important_skills):
            topic = SKILL_TOPIC_MAP.get(skill, skill)
            if topic in seen_topics:
                continue
            seen_topics.add(topic)
            priority_topics_ordered.append((topic, skill))

        final_courses = []
        used_course_ids = set()

        # Pre-convert to dict-records once — 20-30x faster than iterrows()
        course_ranked_records = course_ranked.to_dict("records")

        # Paso 1: un mejor curso por cada topic prioritario.
        for topic, skill in priority_topics_ordered:
            candidates = [
                rec for rec in course_ranked_records
                if rec.get("course_id", "") not in used_course_ids
                and topic in {
                    SKILL_TOPIC_MAP.get(s, s)
                    for s in cmap.get(rec.get("course_id", ""), set())
                }
            ]
            if not candidates:
                continue
            best = max(
                candidates,
                key=lambda r: float(r.get("course_score", 0) or 0)
            )
            used_course_ids.add(best.get("course_id", ""))
            final_courses.append(best)

            # Límite del reranking por topic.
            if len(final_courses) >= 4:
                break

        # Paso 2: set-cover greedy sobre gap_set completo.
        # Ignora topics y maximiza skills nuevas del gap.
        covered_by_step1 = set()
        for fc in final_courses:
            cid = fc.get("course_id", "")
            covered_by_step1.update(cmap.get(cid, set()))

        still_uncovered = gap_set - covered_by_step1

        while len(final_courses) < 10 and still_uncovered:
            best_cid = None
            best_new = 0
            best_score = -1.0
            best_row = None

            for rec in course_ranked_records:
                cid = rec.get("course_id", "")
                if cid in used_course_ids:
                    continue

                new_skills = cmap.get(cid, set()) & still_uncovered
                n_new = len(new_skills)
                score = float(rec.get("course_score", 0) or 0)

                if (n_new > best_new) or (n_new == best_new and score > best_score):
                    best_cid = cid
                    best_new = n_new
                    best_score = score
                    best_row = rec

            if best_cid is None or best_new == 0:
                break

            used_course_ids.add(best_cid)
            final_courses.append(best_row)
            still_uncovered -= cmap.get(best_cid, set())

        # Si quedan slots y no hay más skills que cubrir,
        # rellena con los mejores por score que queden.
        if len(final_courses) < 10:
            for rec in course_ranked_records:
                if len(final_courses) >= 10:
                    break
                cid = rec.get("course_id", "")
                if cid in used_course_ids:
                    continue
                used_course_ids.add(cid)
                final_courses.append(rec)

        if len(final_courses) >= 2:
            top_courses = pd.DataFrame(final_courses).drop(
                columns=["_boost"], errors="ignore"
            )
        else:
            top_courses = course_ranked.head(10).drop(
                columns=["_boost"], errors="ignore"
            ).copy()

    final_skill_set = set(candidate_skills)
    final_skill_set = {canonical_skill_name(s) for s in final_skill_set if canonical_skill_name(s)}
    for mid in top_masters["master_id"].tolist():
        final_skill_set.update(ms.loc[ms["master_id"] == mid, "skill_norm"].astype(str).tolist())
    for cid in top_courses["course_id"].tolist():
        final_skill_set.update(cs.loc[cs["course_id"] == cid, "skill_norm"].astype(str).tolist())

    # --- Text-presence fallback (conservative) ---
    # Only mark a skill as covered if its exact canonical name appears literally
    # in the title or program name of a recommended item — not in generic
    # descriptions. This avoids the "scikit_learn covers machine_learning" overreach:
    # a course must explicitly name the skill to count it.
    _rec_titles: list[str] = []
    for _, _mrow in top_masters.iterrows():
        _rec_titles.append(str(_mrow.get("program_name", "") or "").lower())
    for _, _crow in top_courses.iterrows():
        _rec_titles.append(str(_crow.get("title", "") or "").lower())
    _titles_text = " ".join(_rec_titles)
    for _sk in list(set(target_skills) - final_skill_set):
        _variants = [_sk.replace("_", " "), _sk]
        if any(_v in _titles_text for _v in _variants):
            final_skill_set.add(_sk)

    remaining_after_full_path = sorted(
        set(target_skills) - final_skill_set,
        key=lambda s: (-float(demand_ratios.get(s, 0.0)), -float(demand_counts.get(s, 0.0)), str(s)),
    )
    initial_gap_count = len(gap_set)
    remaining_gap_count = len(remaining_after_full_path)
    closed_gap_count = max(0, initial_gap_count - remaining_gap_count)
    initial_gap_weight = float(sum(float(skill_weight.get(sk, 0.1)) for sk in gap_set))
    remaining_gap_weight = float(sum(float(skill_weight.get(sk, 0.1)) for sk in remaining_after_full_path))
    closed_gap_weight = max(0.0, initial_gap_weight - remaining_gap_weight)
    final_cov = _coverage_by_band(final_skill_set, target_skills, role_bands, demand_w_market)

    edu_score = _education_alignment_score(candidate_profile, target_role) if candidate_profile else 0.0
    exp_score = _experience_projects_score(candidate_profile, target_role, target_skills) if candidate_profile else 0.0
    combo_now = _combo_bonus(candidate_skills_norm, target_role, combos_override=dynamic_combos)
    combo_after = _combo_bonus(final_skill_set, target_role, combos_override=dynamic_combos)
    semantic_now = _semantic_role_fit(candidate_skills_norm, target_role, target_skills, demand_counts)
    semantic_after = _semantic_role_fit(final_skill_set, target_role, target_skills, demand_counts)

    # Market-weighted match:
    # match = sum(weights detected) / sum(weights role)
    # + master bonus (data-related)
    # + technical stack combo bonus
    detected_weight_now = float(sum(float(skill_weight.get(sk, 0.5)) * _cand_skill_weight(sk) for sk in (target_set & candidate_skills_norm)))
    detected_weight_after = float(sum(float(skill_weight.get(sk, 0.5)) for sk in (target_set & final_skill_set)))
    base_now = float(detected_weight_now / max(target_total_weight, 1e-9))
    base_after = float(detected_weight_after / max(target_total_weight, 1e-9))
    structural_now = (
        float(MATCH_COMPONENT_WEIGHTS["weighted_presence"]) * base_now
        + float(MATCH_COMPONENT_WEIGHTS["core_coverage"]) * float(current_cov.get("core", 0.0))
        + float(MATCH_COMPONENT_WEIGHTS["important_coverage"]) * float(current_cov.get("important", 0.0))
        + float(MATCH_COMPONENT_WEIGHTS["complementary_coverage"]) * float(current_cov.get("complementary", 0.0))
        + float(MATCH_COMPONENT_WEIGHTS["semantic_fit"]) * float(semantic_now)
    )
    structural_after = (
        float(MATCH_COMPONENT_WEIGHTS["weighted_presence"]) * base_after
        + float(MATCH_COMPONENT_WEIGHTS["core_coverage"]) * float(final_cov.get("core", 0.0))
        + float(MATCH_COMPONENT_WEIGHTS["important_coverage"]) * float(final_cov.get("important", 0.0))
        + float(MATCH_COMPONENT_WEIGHTS["complementary_coverage"]) * float(final_cov.get("complementary", 0.0))
        + float(MATCH_COMPONENT_WEIGHTS["semantic_fit"]) * float(semantic_after)
    )
    data_master_bonus = 0.07 if bool((candidate_profile or {}).get("has_data_related_master", False)) else 0.0
    combo_bonus_now = 0.05 if combo_now >= 0.67 else (0.03 if combo_now >= 0.5 else 0.0)
    combo_bonus_after = 0.05 if combo_after >= 0.67 else (0.03 if combo_after >= 0.5 else 0.0)
    core_missing_now = len(current_cov.get("core_missing", []) or [])
    core_missing_after = len(final_cov.get("core_missing", []) or [])
    penalty_now = _core_missing_penalty(
        core_cov=float(current_cov.get("core", 0.0)),
        missing_core=core_missing_now,
        core_total=int(current_cov.get("core_count", 0) or 0),
    )
    penalty_after = _core_missing_penalty(
        core_cov=float(final_cov.get("core", 0.0)),
        missing_core=core_missing_after,
        core_total=int(final_cov.get("core_count", 0) or 0),
    )
    skill_match_now = float(max(0.0, min(1.0, structural_now)))
    skill_match_after = float(max(0.0, min(1.0, structural_after)))
    match_now = (0.5 * skill_match_now + 0.3 * float(edu_score) + 0.2 * float(exp_score) + data_master_bonus + combo_bonus_now) * penalty_now
    match_after = (0.5 * skill_match_after + 0.3 * float(edu_score) + 0.2 * float(exp_score) + data_master_bonus + combo_bonus_after) * penalty_after
    calibrator = _load_match_calibrator()
    match_now = _apply_match_calibration(match_now, target_role, calibrator)
    match_after = _apply_match_calibration(match_after, target_role, calibrator)
    has_stem = bool((candidate_profile or {}).get("has_stem_background", False))
    has_data_master = bool((candidate_profile or {}).get("has_data_related_master", False))
    if has_stem and has_data_master and target_role in {"data_analyst", "data_scientist", "data_engineer", "ml_engineer"}:
        match_now = max(float(match_now), 0.45)
        match_after = max(float(match_after), 0.55)
    match_now = float(max(0.0, min(1.0, match_now)))
    match_after = float(max(match_now, min(1.0, match_after)))

    return {
        "target_skills": target_skills,
        "gap_skills": gap,
        "gap_skills_market_priority": gap,
        "remaining_gap": remaining_after_full_path,
        "gap_coverage_ratio": (closed_gap_count / max(initial_gap_count, 1)),
        "gap_coverage_ratio_weighted": (closed_gap_weight / max(initial_gap_weight, 1.0)),
        "role_match_ratio_weighted": round(role_match_ratio_weighted, 3),
        "role_core_coverage": round(float(current_cov.get("core", 0.0)), 3),
        "role_important_coverage": round(float(current_cov.get("important", 0.0)), 3),
        "role_complementary_coverage": round(float(current_cov.get("complementary", 0.0)), 3),
        "role_optional_coverage": round(float(current_cov.get("optional", 0.0)), 3),
        "role_core_coverage_after_path": round(float(final_cov.get("core", 0.0)), 3),
        "role_important_coverage_after_path": round(float(final_cov.get("important", 0.0)), 3),
        "role_complementary_coverage_after_path": round(float(final_cov.get("complementary", 0.0)), 3),
        "role_optional_coverage_after_path": round(float(final_cov.get("optional", 0.0)), 3),
        "missing_core_skills": current_cov.get("core_missing", []),
        "missing_important_skills": current_cov.get("important_missing", []),
        "missing_complementary_skills": current_cov.get("complementary_missing", []),
        "role_match_score_current": round(100.0 * match_now, 1),
        "role_match_score_after_path": round(100.0 * match_after, 1),
        "education_alignment_score": round(float(edu_score), 3),
        "experience_projects_score": round(float(exp_score), 3),
        "skill_match_component_current": round(float(skill_match_now), 3),
        "skill_match_component_after_path": round(float(skill_match_after), 3),
        "combo_bonus_current": round(float(combo_now), 3),
        "combo_bonus_after_path": round(float(combo_after), 3),
        "semantic_fit_current": round(float(semantic_now), 3),
        "semantic_fit_after_path": round(float(semantic_after), 3),
        "target_demand_weight_total": round(target_total_weight, 3),
        "target_demand_weight_present": round(present_weight, 3),
        "gap_closed_count": closed_gap_count,
        "gap_closed_weighted": round(closed_gap_weight, 3),
        "gap_initial_count": initial_gap_count,
        "gap_initial_weighted": round(initial_gap_weight, 3),
        "inferred_skills": (candidate_profile or {}).get("inferred_skills", []),
        "candidate_skill_sources": (candidate_profile or {}).get("candidate_skill_sources", {}),
        "top_masters": top_masters,
        "top_courses": top_courses,
        "embedding_mode": emb_mode,
        "reranker_used": master_reranker_model is not None,
        "final_skill_set": final_skill_set,
        "candidate_profile": candidate_profile or {},
        "detected_best_role": role_fit.get("detected_best_role", ""),
        "detected_best_role_score": int(role_fit.get("detected_best_role_score", 0) or 0),
        "role_scores_all": role_fit.get("role_scores_all", {}),
    }


def filter_linkedin_spain_us_jobs(jobs: pd.DataFrame) -> pd.DataFrame:
    """Keep the recommendation pool focused on recent LinkedIn markets requested by the app."""
    if jobs is None or jobs.empty:
        return jobs
    out = jobs.copy()
    if "site" in out.columns:
        out = out[out["site"].fillna("").astype(str).str.lower().eq("linkedin")].copy()
    if out.empty:
        return out

    location = out.get("location", pd.Series("", index=out.index)).fillna("").astype(str)
    search_location = out.get("search_location", pd.Series("", index=out.index)).fillna("").astype(str)
    market_text = (location + " " + search_location).str.lower()

    spain_pattern = (
        r"\b(?:spain|espana|españa|madrid|barcelona|catalonia|catalunya|valencia|valencian|"
        r"andalusia|andalucia|sevilla|seville|bilbao|basque|malaga|málaga|zaragoza|"
        r"alicante|murcia|galicia|pamplona|valladolid|granada|cordoba|córdoba|"
        r"palma|santiago|community of madrid|gandia|gandía)\b"
    )
    us_pattern = (
        r"\b(?:united states|usa|u\.s\.|new york|san francisco|seattle|austin|boston|"
        r"chicago|los angeles|palo alto|santa clara|atlanta|dallas|houston|miami|"
        r"washington|denver|phoenix|portland|philadelphia|raleigh|charlotte|"
        r"basking ridge|manhattan|hunstville|huntsville)\b"
        r"|,\s*(?:al|ak|az|ar|ca|co|ct|dc|de|fl|ga|hi|ia|id|il|in|ks|ky|la|ma|md|me|"
        r"mi|mn|mo|ms|mt|nc|nd|ne|nh|nj|nm|nv|ny|oh|ok|or|pa|ri|sc|sd|tn|tx|ut|"
        r"va|vt|wa|wi|wv|wy)\b"
    )
    market_mask = market_text.str.contains(spain_pattern, regex=True, na=False) | market_text.str.contains(us_pattern, regex=True, na=False)
    return out[market_mask].copy()


def recommend_jobs(
    target_role: str,
    final_skill_set: set[str],
    jobs_feat: pd.DataFrame,
    job_skills: pd.DataFrame,
    candidate_profile: dict | None = None,
):
    final_skill_norm = {canonical_skill_name(s) for s in (final_skill_set or set()) if canonical_skill_name(s)}
    jobs = filter_linkedin_spain_us_jobs(jobs_feat)
    if "role_family" in jobs.columns:
        filt = jobs["role_family"].fillna("").str.lower() == target_role.lower()
        if filt.any():
            jobs = jobs[filt].copy()

    js = job_skills.copy()
    js["skill"] = js["skill"].astype(str)
    js["skill_norm"] = js["skill"].map(canonical_skill_name)
    js = js[js["skill_norm"] != ""].copy()

    user_seniority = str((candidate_profile or {}).get("inferred_seniority", "mid_level"))
    domain_exp = (candidate_profile or {}).get("experience_years_relevant_by_domain", {})
    role_domains = ROLE_DOMAIN_HINTS.get(target_role, set())
    role_domain_mean = 0.0
    if role_domains:
        role_domain_mean = sum(float(domain_exp.get(d, 0.0)) for d in role_domains) / max(len(role_domains), 1)
    role_domain_signal = max(0.0, min(1.0, min(role_domain_mean, 6.0) / 6.0))
    edu_rel_map = (candidate_profile or {}).get("education_relevance_by_role", {}) or {}
    education_signal = float(edu_rel_map.get(target_role, (candidate_profile or {}).get("education_data_relevance", 0.0)) or 0.0)
    has_data_master = bool((candidate_profile or {}).get("has_data_related_master", False))

    rec = []
    for jid, grp in js.groupby("job_id"):
        jskills = set(grp["skill_norm"].tolist())
        if not jskills:
            continue
        overlap = len(jskills & final_skill_norm)
        skill_score = overlap / max(len(jskills), 1)
        rec.append((jid, overlap, len(jskills), skill_score))

    rec_df = pd.DataFrame(rec, columns=["job_id", "skill_overlap", "job_skill_count", "skill_score"])
    out = jobs.merge(rec_df, on="job_id", how="inner")
    out["title_role_score"] = out["title"].fillna("").astype(str).map(lambda t: text_role_overlap_score(t, target_role) or 0.0)
    user_level = SENIORITY_ORDER.get(user_seniority, 2)
    if "seniority" in out.columns:
        out["target_seniority_level"] = out["seniority"].fillna("").astype(str).map(_seniority_target_from_text).astype(int)
        out["seniority_fit"] = out["seniority"].fillna("").astype(str).map(lambda s: _seniority_fit_score(user_seniority, s))
    else:
        out["target_seniority_level"] = 2
        out["seniority_fit"] = 0.6
    out["experience_fit"] = role_domain_signal
    out["education_fit"] = education_signal
    out["match_score"] = (
        0.52 * out["skill_score"].astype(float)
        + 0.20 * out["title_role_score"].astype(float)
        + 0.12 * out["seniority_fit"].astype(float)
        + 0.08 * out["experience_fit"].astype(float)
        + 0.08 * out["education_fit"].astype(float)
    )
    if has_data_master and target_role in {"data_scientist", "ml_engineer", "data_engineer"}:
        out["match_score"] = (out["match_score"].astype(float) + 0.03).clip(upper=1.0)
    if "date_posted" in out.columns:
        posted_dt = pd.to_datetime(out["date_posted"], errors="coerce", utc=False)
        valid_dt = (
            posted_dt.notna()
            & (posted_dt >= pd.Timestamp(year=2025, month=1, day=1))
        )
        # Use dataset's most recent date as reference so recency is meaningful
        # even for static/scraped datasets (avoids all scores being 0 after 30 days).
        dataset_ref = posted_dt[valid_dt].max() if valid_dt.any() else pd.Timestamp.now()
        age_days = (dataset_ref - posted_dt).dt.total_seconds() / 86400.0
        # Window: 180 days gives good spread across the dataset
        out["recency_score"] = 0.0
        out.loc[valid_dt, "recency_score"] = (1.0 - (age_days[valid_dt] / 180.0)).clip(lower=0.0, upper=1.0)
    else:
        out["recency_score"] = 0.0
    out["job_ranking_score"] = (
        0.70 * out["match_score"].astype(float)
        + 0.30 * out["recency_score"].astype(float)
    ).clip(upper=1.0)
    # Aspirational roles: notably above current seniority or with low seniority fit.
    out["is_aspirational"] = (
        (out["target_seniority_level"].astype(int) >= int(user_level) + 2)
        | (out["seniority_fit"].astype(float) < 0.55)
    )
    out = out.sort_values(
        ["is_aspirational", "job_ranking_score", "recency_score", "match_score", "skill_overlap"],
        ascending=[True, False, False, False, False],
    )
    return out.head(35)


def main():
    p = argparse.ArgumentParser(description="CAIQ recommendation model: CV -> gap -> masters/courses -> jobs")
    p.add_argument("--etl-dir", default=None)
    p.add_argument("--taxonomy", default=None)
    p.add_argument("--resume-text", default="", help="Resume/CV text")
    p.add_argument("--resume-pdf", default="", help="Path to CV PDF")
    p.add_argument("--target-role", default="ml_engineer", choices=["ml_engineer", "data_engineer", "data_scientist", "data_analyst", "other_data_role"])
    p.add_argument("--max-price", type=float, default=None)
    p.add_argument("--location", default="")
    p.add_argument("--study-keyword", default="")
    p.add_argument("--out-dir", default=None)
    p.add_argument("--weight-coverage", type=float, default=0.6)
    p.add_argument("--weight-semantic", type=float, default=0.4)
    p.add_argument("--use-master-reranker", action="store_true")
    p.add_argument("--master-reranker-path", default=None)
    p.add_argument("--reranker-blend", type=float, default=0.7)
    args = p.parse_args()

    etl_dir = Path(args.etl_dir)
    out_dir = Path(args.out_dir)
    out_dir.mkdir(parents=True, exist_ok=True)

    taxonomy = load_taxonomy(Path(args.taxonomy))

    resume_text = norm_text(args.resume_text)
    if args.resume_pdf:
        pdf_text = read_resume_pdf_text(Path(args.resume_pdf))
        if pdf_text:
            resume_text = pdf_text
    if not resume_text:
        raise ValueError("Provide --resume-text or --resume-pdf with readable content")

    masters_feat = pd.read_csv(etl_dir / "outputs" / "semantic" / "masters_features.csv")
    courses_feat = pd.read_csv(etl_dir / "outputs" / "semantic" / "courses_features.csv")
    jobs_feat = pd.read_csv(etl_dir / "outputs" / "semantic" / "jobs_features.csv")
    role_skill_demand = pd.read_csv(etl_dir / "outputs" / "semantic" / "role_skill_demand.csv")
    master_skills = pd.read_csv(etl_dir / "outputs" / "curated" / "master_skills.csv")
    course_skills = pd.read_csv(etl_dir / "outputs" / "curated" / "course_skills.csv")
    job_skills = pd.read_csv(etl_dir / "outputs" / "curated" / "job_skills.csv")

    candidate_profile = build_candidate_profile_hybrid(resume_text, taxonomy)
    candidate_skills = set(candidate_profile.get("skills_detected", []))

    master_reranker = try_load_reranker_model(args.master_reranker_path) if args.use_master_reranker else None

    rec = recommend_learning_path(
        candidate_skills=candidate_skills,
        target_role=args.target_role,
        role_skill_demand=role_skill_demand,
        masters_feat=masters_feat,
        master_skills=master_skills,
        courses_feat=courses_feat,
        course_skills=course_skills,
        filters={"max_price": args.max_price, "location": args.location, "study_keyword": args.study_keyword},
        weight_coverage=args.weight_coverage,
        weight_semantic=args.weight_semantic,
        master_reranker_model=master_reranker,
        reranker_blend=args.reranker_blend,
        candidate_profile=candidate_profile,
        taxonomy=taxonomy,
    )

    jobs = recommend_jobs(args.target_role, rec["final_skill_set"], jobs_feat, job_skills, candidate_profile=candidate_profile)

    rec["top_masters"].to_csv(out_dir / "recommended_masters.csv", index=False, encoding="utf-8")
    rec["top_courses"].to_csv(out_dir / "recommended_courses.csv", index=False, encoding="utf-8")
    jobs.to_csv(out_dir / "recommended_jobs.csv", index=False, encoding="utf-8")

    summary = {
        "target_role": args.target_role,
        "embedding_mode": rec["embedding_mode"],
        "recall_holdout": float(rec.get("recall_holdout", 0.0)),
        "gap_reduction": float(rec.get("gap_reduction", 0.0)),
        "coverage_score": float(rec.get("coverage_score", 0.0)),
    }
    (out_dir / "recommendation_summary.json").write_text(
        json.dumps(summary, indent=2, ensure_ascii=False), encoding="utf-8"
    )
    print(json.dumps(summary, indent=2))


if __name__ == "__main__":
    main()
