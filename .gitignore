# ============================================================
# CAIQ - .gitignore
# ============================================================

# --- Datos personales: nunca subir ---
data/private/
04_validacion/casos_cv/
docs/validation/outputs/

# --- Datos scrapeados y procesados: volumen y no codigo ---
scrappings/
_historico/
01_etl/outputs/
03_aplicacion/outputs/
**/outputs/
02_modelo/artefactos/recommended_*.csv
02_modelo/artefactos/recommendation_summary.json
job_url_status.csv

# --- Modelos binarios regenerables ---
02_modelo/artefactos/*.pkl
01_etl/reports/model_*.pkl

# --- Logs ---
logs/
*.log
**/streamlit*.log

# --- Copias legacy y duplicadas ---
02_modelo/
03_aplicacion/
04_validacion/
/figures/
/docs/figures/

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.pytest_cache/
.env
.venv/
venv/

# --- Documentos Word y borradores TFM ---
thesis/drafts/
*.docx
~$*.docx
*.tmp
~WRL*.tmp

# --- LaTeX: salida compilada ---
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc
*.pdf

# --- Sistema ---
.DS_Store
Thumbs.db
desktop.ini
